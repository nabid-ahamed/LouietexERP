@using Microsoft.AspNetCore.Identity
@using LouietexERP.Models
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en" id="main-html">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LouietexERP</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">

                <a class="navbar-brand d-flex align-items-center" asp-controller="Dashboard" asp-action="Index">
                    <img src="~/images/logo.png" alt="Logo" style="height:40px; margin-right:10px;" />
                    <span>ERP</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <!-- LEFT MENU -->
                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Dashboard" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Inventories" asp-action="Index">Inventory</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Employees" asp-action="Index">Employees</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Productions" asp-action="Index">Production</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Orders" asp-action="Index">Orders</a>
                        </li>

                        @if (User.Identity.IsAuthenticated && User.IsInRole("NormalUser"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Profile" asp-action="RequestChange">
                                    Request Profile Change
                                </a>
                            </li>
                        }

                        @if (User.Identity.IsAuthenticated && User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-controller="UserManagement" asp-action="PendingApprovals">
                                    Approve Users
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold" asp-controller="UserManagement" asp-action="ViewModifications">
                                    Profile Requests
                                </a>
                            </li>
                        }

                    </ul>

                    <!-- RIGHT SIDE -->
                    <div class="ms-auto d-flex align-items-center gap-2">

                        <!-- 🌙 THEME TOGGLE -->
                        <button class="btn btn-link nav-link" id="theme-toggle" title="Toggle Theme">
                            <i id="theme-icon" class="bi bi-moon-fill"></i>
                        </button>

                        <partial name="_LoginPartial" />

                    </div>

                </div>
            </div>
        </nav>
    </header>

    <!-- ALERTS -->
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning text-center">
            @TempData["Warning"]
        </div>
    }

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["Message"]
        </div>
    }

    <!-- MAIN -->
    <div class="container main-content">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="footer text-center border-top">
        <div class="container">
            &copy; @DateTime.Now.Year - LouietexERP - Nabid Ahamed Noushad
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- ✅ ONLY ONE THEME SCRIPT -->
    <script>
            const htmlElement = document.getElementById('main-html');
            const themeToggle = document.getElementById('theme-toggle');
            const themeIcon = document.getElementById('theme-icon');

            if (themeToggle) {

                const savedTheme = localStorage.getItem('theme') || 'light';
                htmlElement.setAttribute('data-bs-theme', savedTheme);
                updateIcon(savedTheme);

                themeToggle.addEventListener('click', async () => {
                    const currentTheme = htmlElement.getAttribute('data-bs-theme');
                    const newTheme = currentTheme === 'light' ? 'dark' : 'light';

                    htmlElement.setAttribute('data-bs-theme', newTheme);
                    localStorage.setItem('theme', newTheme);
                    updateIcon(newTheme);

                    // OPTIONAL: backend save
                    try {
                        await fetch('/Profile/SaveTheme', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ theme: newTheme })
                        });
                    } catch (e) {
                        console.log("Theme save skipped");
                    }
                });

                function updateIcon(theme) {
                    if (theme === 'dark') {
                        themeIcon.classList.replace('bi-moon-fill', 'bi-sun-fill');
                    } else {
                        themeIcon.classList.replace('bi-sun-fill', 'bi-moon-fill');
                    }
                }
            }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>