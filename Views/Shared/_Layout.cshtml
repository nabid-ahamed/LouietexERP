@using Microsoft.AspNetCore.Identity
@using LouietexERP.Models
@inject UserManager<ApplicationUser> UserManager

@{
    var path = Context.Request.Path.ToString().ToLowerInvariant();

    var isAuthPage = path.Contains("/identity/account/login") ||
                     path.Contains("/identity/account/register");

    Func<string, string, string> isActive = (controller, action) =>
        path.Contains($"/{controller.ToLower()}/{action.ToLower()}") ? "active" : "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LouietexERP</title>

    <!-- CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-light bg-white border-bottom px-3 fixed-top">
        <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">
            <img src="~/images/logo.png" style="height:40px;" />
        </a>

        <div class="ms-auto">
            <partial name="_LoginPartial" />
        </div>
    </nav>

    <!-- SIDEBAR -->
    @if (!isAuthPage)
    {
        <div class="sidebar">

            <h5>ERP Menu</h5>

            <a class="@isActive("Dashboard", "Index")"
                   asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-speedometer2"></i>
                <span>Home</span>
            </a>

            <a class="@isActive("Inventories", "Index")"
                   asp-controller="Inventories" asp-action="Index">
                <i class="bi bi-box"></i>
                <span>Inventory</span>
            </a>

            <a class="@isActive("Employees", "Index")"
                   asp-controller="Employees" asp-action="Index">
                <i class="bi bi-people"></i>
                <span>Employees</span>
            </a>

            <a class="@isActive("Productions", "Index")"
                   asp-controller="Productions" asp-action="Index">
                <i class="bi bi-gear"></i>
                <span>Production</span>
            </a>

            <a class="@isActive("Orders", "Index")"
                   asp-controller="Orders" asp-action="Index">
                <i class="bi bi-cart"></i>
                <span>Orders</span>
            </a>

        </div>
    }

    <!-- MAIN CONTENT -->
    <div class="main-area">

        <!-- ALERTS -->
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning text-center m-3">
                @TempData["Warning"]
            </div>
        }

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success text-center m-3">
                @TempData["Message"]
            </div>
        }

        <main class="content">
            @RenderBody()
        </main>

    </div>

    <!-- FOOTER -->
    <footer class="footer text-center">
        &copy; @DateTime.Now.Year - LouietexERP - Nabid Ahamed Noushad
    </footer>

    <!-- SCRIPTS (IMPORTANT FIX) -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>