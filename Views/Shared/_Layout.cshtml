@using Microsoft.AspNetCore.Identity
@using LouietexERP.Models
@inject UserManager<ApplicationUser> UserManager

@{
    var path = Context.Request.Path.ToString().ToLowerInvariant();

    var isAuthPage = path.Contains("/identity/account/login") ||
                     path.Contains("/identity/account/register");

    var isSuperAdmin = User.IsInRole("SuperAdmin");
    var isAdmin = User.IsInRole("Admin");

    var hideNav = ViewData["HideNav"] as bool? ?? false;

    // ✅ SAFE ACTIVE MENU (NO STRING MATCH BUG)
    Func<string, string, string> isActive = (controller, action) =>
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        return currentController == controller && currentAction == action ? "active" : "";
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LouietexERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="@(hideNav ? "no-nav-layout" : "")">

    <!-- NAVBAR -->
    @if (!hideNav)
    {
        <nav class="navbar navbar-light bg-white border-bottom px-3 fixed-top">
            <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">
                <img src="~/images/logo.png" class="logo" />
            </a>

            <div class="ms-auto">
                <partial name="_LoginPartial" />
            </div>
        </nav>
    }

    <!-- SIDEBAR -->
    @if (!isAuthPage && !hideNav)
    {
        <div class="sidebar">

            <h5 class="px-3">ERP Menu</h5>

            <!-- Dashboard -->
            <a class="@isActive("Dashboard", "Index")"
                   asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-speedometer2"></i>
                <span>Home</span>
            </a>

            <!-- Inventory -->
            @if (isAdmin || isSuperAdmin)
            {
                <a class="@isActive("Inventories", "Index")"
                       asp-controller="Inventories" asp-action="Index">
                    <i class="bi bi-box"></i>
                    <span>Inventory</span>
                </a>
            }

            <!-- Employees -->
            @if (isSuperAdmin)
            {
                <a class="@isActive("Employees", "Index")"
                       asp-controller="Employees" asp-action="Index">
                    <i class="bi bi-people"></i>
                    <span>Employees</span>
                </a>
            }

            <!-- Production -->
            @if (isAdmin || isSuperAdmin)
            {
                <a class="@isActive("Productions", "Index")"
                       asp-controller="Productions" asp-action="Index">
                    <i class="bi bi-gear"></i>
                    <span>Production</span>
                </a>
            }

            <!-- Orders -->
            <a class="@isActive("Orders", "Index")"
                   asp-controller="Orders" asp-action="Index">
                <i class="bi bi-cart"></i>
                <span>Orders</span>
            </a>
            <!-- Order Status -->
            <a class="@isActive("Orders", "TrackStatus")"
                   asp-controller="Orders" asp-action="TrackStatus">
                <i class="bi bi-truck"></i>
                <span>Order Status</span>
            </a>
            @if (User.IsInRole("SuperAdmin"))
            {
                <a class="@isActive("UserAccess", "Index")"
                       asp-controller="UserAccess" asp-action="Index">
                    <i class="bi bi-shield-lock"></i>
                    <span>User Access Control</span>
                </a>
            }
            
            <!-- Review Requests -->
            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
            {
                <a class="@isActive("UserManagement", "ViewModifications")"
                       asp-controller="UserManagement" asp-action="ViewModifications">
                    <i class="bi bi-clipboard-check"></i>
                    <span>Review Requests</span>
                </a>
            }
        </div>
    }

    <!-- MAIN CONTENT -->
    <div class="main-area">

        <!-- ALERTS -->
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning text-center m-3">
                @TempData["Warning"]
            </div>
        }

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success text-center m-3">
                @TempData["Message"]
            </div>
        }

        <main class="content">
            @RenderBody()
        </main>

    </div>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @await RenderSectionAsync("Scripts", required: false)


    <!-- FOOTER -->
    <footer class="footer mt-auto py-3 border-top" style="background-color: #2b2b2b;">
        <div class="text-center">
            <span style="color: #aaa; font-size: 0.85rem;">
                © 2026 Louietex |Nabid Ahamed Noushad. All rights reserved
            </span>
        </div>
    </footer>
</body>
</html>