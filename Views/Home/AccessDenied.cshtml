@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_Layout.cshtml"; // or use null if no layout is desired
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h1 class="display-1 text-danger"><i class="bi bi-shield-lock-fill"></i></h1>
            <h2 class="mb-4">Access Denied</h2>
            <p class="lead mb-4">You do not have permission to view this resource.</p>
            <p class="text-muted mb-5">Please contact your system administrator if you believe this is an error.</p>
            <a href="/" class="btn btn-primary px-4 py-2">
                <i class="bi bi-house-door me-2"></i>Return to Home
            </a>
        </div>
    </div>
</div>
