@model LouietexERP.Models.Order

@{
    ViewData["Title"] = "Order Details";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">

        <!-- Header -->
        <div class="card-header bg-dark text-white rounded-top-4 d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Order Details</h4>
        </div>

        <!-- Body -->
        <div class="card-body p-4">

            <div class="row mb-3">
                <div class="col-md-4 fw-semibold text-muted">Buyer Name</div>
                <div class="col-md-8">@Model.BuyerName</div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-semibold text-muted">Style / Item Code</div>
                <div class="col-md-8">@Model.StyleCode</div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-semibold text-muted">Total Quantity</div>
                <div class="col-md-8">
                    <span class="badge bg-info text-dark fs-6 px-3 py-2">
                        @Model.TotalQuantity
                    </span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-semibold text-muted">Delivery Date</div>
                <div class="col-md-8">
                    @Model.DeliveryDate.ToString("dd-MMM-yyyy")
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-semibold text-muted">Order Status</div>
                <div class="col-md-8">
                    @{
                        var status = Model.Status ?? "Pending";
                        var badgeClass = status == "Completed" ? "bg-success" :
                                         status == "Approved" ? "bg-primary" :
                                         status == "In Production" ? "bg-warning text-dark" :
                                         status == "Delivered" ? "bg-success" :
                                         status == "Cancelled" ? "bg-danger" :
                                         "bg-secondary";
                    }

                    <span class="badge @badgeClass fs-6 px-3 py-2">
                        @status
                    </span>
                </div>
            </div>

        </div>

        <!-- Footer -->
        <div class="card-footer bg-light d-flex justify-content-end">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">
                Back
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                Edit
            </a>
        </div>

    </div>
</div>