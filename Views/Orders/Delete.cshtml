@model LouietexERP.Models.Order

@{
    ViewData["Title"] = "Delete Order";
}

<div class="fade-in-up container" style="max-width: 600px; margin-top: 50px;">
    <div class="erp-card border-danger shadow-sm">
        <div class="card-header bg-danger bg-opacity-10 border-bottom border-danger border-opacity-25 p-4 text-center">
            <div class="rounded-circle bg-danger bg-opacity-25 d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <i class="bi bi-cart-x text-danger fs-1"></i>
            </div>
            <h3 class="fw-bold text-danger mb-1">Cancel Order?</h3>
            <p class="text-muted small mb-0">You are about to permanently delete this order. This cannot be undone.</p>
        </div>
        
        <div class="card-body p-4">
            <div class="bg-light rounded-3 p-4 mb-4">
                <div class="text-center mb-4">
                    <div class="text-muted small uppercase fw-bold mb-1" style="font-size: 0.65rem; letter-spacing: 1px;">BUYER & STYLE</div>
                    <h5 class="fw-bold text-dark mb-0">@Model.BuyerName</h5>
                    <div class="text-primary fw-bold">@Model.StyleCode</div>
                </div>
                
                <div class="row g-3">
                    <div class="col-6">
                        <div class="text-muted small uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 1px;">QUANTITY</div>
                        <div class="fw-medium text-dark">@Model.TotalQuantity.ToString("N0") pcs</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 1px;">DELIVERY</div>
                        <div class="fw-medium text-dark">@Model.DeliveryDate.ToString("dd MMM, yyyy")</div>
                    </div>
                    <div class="col-12">
                        <div class="text-muted small uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 1px;">CURRENT STATUS</div>
                        <span class="badge bg-secondary">@Model.Status</span>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" class="d-flex gap-3">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn-premium btn-premium-danger flex-grow-1 justify-content-center">
                    <i class="bi bi-trash3"></i> Yes, Delete Order
                </button>
                <a asp-action="Index" class="btn btn-light px-4 border rounded-3 fw-bold">Cancel</a>
            </form>
        </div>
    </div>
</div>
