@model IEnumerable<LouietexERP.Models.Employee>
@{
    ViewData["Title"] = "HR & Workforce Analytics";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center mb-4">
        <a href="/Reports/Index" class="btn btn-light rounded-circle p-3 me-3 shadow-sm border"><i class="bi bi-arrow-left fs-5"></i></a>
        <div>
            <h2 class="fw-bold text-dark mb-0">HR & Workforce Analytics</h2>
            <p class="text-muted mb-0">Department distribution and workforce statistics.</p>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-6 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100 border-start border-4 border-primary">
                <h6 class="text-muted small text-uppercase fw-bold mb-3">Total Workforce</h6>
                <div class="d-flex align-items-center">
                    <h1 class="fw-bold mb-0 me-3">@ViewBag.TotalStaff</h1>
                    <span class="badge bg-light-primary text-primary rounded-pill">Active Employees</span>
                </div>
            </div>
        </div>
        <div class="col-xl-6 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100 border-start border-4 border-info">
                <h6 class="text-muted small text-uppercase fw-bold mb-3">Departments</h6>
                <div class="d-flex align-items-center">
                    <h1 class="fw-bold mb-0 me-3">@ViewBag.Depts</h1>
                    <span class="badge bg-light-info text-info rounded-pill">Active Depts</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom py-3 px-4 text-center">
                    <h6 class="fw-bold m-0 text-dark">Department Distribution</h6>
                </div>
                <div class="card-body p-4">
                    <canvas id="deptChart" style="height: 350px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-xl-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom py-3 px-4">
                    <h6 class="fw-bold m-0 text-dark">Employee List Summary</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Employee</th>
                                    <th>Dept</th>
                                    <th class="pe-4">Role</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var emp in Model.Take(6))
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-bold text-dark">@emp.FullName</div>
                                        </td>
                                        <td>@emp.Department</td>
                                        <td class="pe-4">@emp.Role</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            new Chart(document.getElementById('deptChart'), {
                type: 'pie',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.GroupBy(e => e.Department).Select(g => g.Key))),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.GroupBy(e => e.Department).Select(g => g.Count()))),
                        backgroundColor: ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b', '#858796']
                    }]
                }
            });
        });
    </script>
}
