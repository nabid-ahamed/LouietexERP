@model LouietexERP.Models.QCInspection

@{
    ViewData["Title"] = "Edit QC Inspection";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-warning text-dark rounded-top-4 p-4">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-pencil-square fs-4 me-2"></i>
                        <h5 class="mb-0 fw-bold">Edit Inspection</h5>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CheckedByUserId" />
                        <input type="hidden" asp-for="CreatedAt" />
                        <input type="hidden" asp-for="InspectionDate" />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Select Customer Order <span class="text-danger">*</span></label>
                                <select id="orderSelect" class="form-select">
                                    <option value="">-- Select Order / Batch --</option>
                                    @if (ViewBag.Orders != null)
                                    {
                                        foreach (var order in (IEnumerable<LouietexERP.Models.Order>)ViewBag.Orders)
                                        {
                                            var isSelected = (ViewBag.SelectedOrderId != null && (int)ViewBag.SelectedOrderId == order.Id);
                                            if (isSelected)
                                            {
                                                <option value="@order.Id" selected="selected">@order.StyleCode (@order.BuyerName)</option>
                                            }
                                            else
                                            {
                                                <option value="@order.Id">@order.StyleCode (@order.BuyerName)</option>
                                            }
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ProductionId" class="form-label fw-bold">Production Line / Run <span class="text-danger">*</span></label>
                                <select asp-for="ProductionId" class="form-select" id="productionSelect">
                                    <option value="">-- Select Production Line --</option>
                                    @if (ViewBag.Productions != null)
                                    {
                                        foreach (var prod in (IEnumerable<LouietexERP.Models.Production>)ViewBag.Productions)
                                        {
                                            <option value="@prod.Id" data-order-id="@prod.OrderId">
                                                @prod.LineNumber (Supervisor: @(prod.Supervisor ?? "N/A"))
                                            </option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="ProductionId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="QCStatus" class="form-label fw-bold">QC Result <span class="text-danger">*</span></label>
                                <select asp-for="QCStatus" class="form-select">
                                    <option value="Passed">Passed</option>
                                    <option value="Failed">Failed</option>
                                    <option value="Recheck Required">Recheck Required</option>
                                </select>
                                <span asp-validation-for="QCStatus" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="DefectCount" class="form-label fw-bold">Defect Count</label>
                                <input asp-for="DefectCount" class="form-control" />
                                <span asp-validation-for="DefectCount" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="InspectorName" class="form-label fw-bold">Inspector Name</label>
                                <input asp-for="InspectorName" class="form-control" placeholder="Optional Name" />
                                <span asp-validation-for="InspectorName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="Remarks" class="form-label fw-bold">Remarks / Notes</label>
                                <textarea asp-for="Remarks" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Remarks" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-warning px-4">
                                <i class="bi bi-save me-2"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const orderSelect = document.getElementById("orderSelect");
            const productionSelect = document.getElementById("productionSelect");
            
            // Store the initial selected production run value
            const initialProductionId = "@Model.ProductionId";
            
            // Store all original production options
            const originalOptions = Array.from(productionSelect.querySelectorAll("option"));
            
            function filterProductions() {
                const selectedOrderId = orderSelect.value;
                
                // Clear and reset the production select
                productionSelect.innerHTML = "";
                
                if (!selectedOrderId) {
                    // Disable and add only the placeholder
                    productionSelect.appendChild(originalOptions[0]);
                    productionSelect.value = "";
                    productionSelect.disabled = true;
                    return;
                }
                
                // Filter options matching the selected OrderId
                const filteredOptions = originalOptions.filter((option, index) => {
                    if (index === 0) return true; // Keep placeholder
                    return option.getAttribute("data-order-id") === selectedOrderId;
                });
                
                // Add matching options to select
                filteredOptions.forEach(option => productionSelect.appendChild(option));
                
                // Enable select
                productionSelect.disabled = false;
                
                // Restore selection if it matches the initial ID, otherwise clear select
                const matchingOption = filteredOptions.find(opt => opt.value === initialProductionId);
                if (matchingOption) {
                    productionSelect.value = initialProductionId;
                } else {
                    productionSelect.value = "";
                }
            }
            
            orderSelect.addEventListener("change", filterProductions);
            
            // Trigger initial filtering on load
            filterProductions();
        });
    </script>
}
