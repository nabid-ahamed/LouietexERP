@model IEnumerable<LouietexERP.Models.Inventory>

@{
    ViewData["Title"] = "Low Stock Alert";
}

<div class="container-fluid px-4 py-4">
    <!-- Header Section -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i> Low Stock Alerts
            </h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/Dashboard/Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/Inventories/Index">Inventory</a></li>
                    <li class="breadcrumb-item active">Low Stock</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <a href="/Inventories/Index" class="btn btn-outline-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-box-seam me-2"></i> Full Inventory
            </a>
            <a href="/Inventories/Create" class="btn btn-primary rounded-pill px-4 shadow">
                <i class="bi bi-plus-lg me-2"></i> Add Stock
            </a>
        </div>
    </div>

    <!-- Alert Banner -->
    <div class="alert alert-danger border-0 shadow-sm rounded-4 d-flex align-items-center p-4 mb-4" role="alert">
        <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center me-4 pulse-danger" style="width: 50px; height: 50px; flex-shrink: 0;">
            <i class="bi bi-megaphone-fill fs-4"></i>
        </div>
        <div>
            <h5 class="alert-heading fw-bold mb-1">Critical Stock Warning</h5>
            <p class="mb-0">There are <strong>@Model.Count()</strong> items requiring immediate replenishment to avoid production delays.</p>
        </div>
    </div>

    <!-- Inventory Table Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3 px-4 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary">Critical Items List</h6>
            <div class="input-group input-group-sm" style="width: 250px;">
                <span class="input-group-text bg-light border-end-0 rounded-start-pill"><i class="bi bi-search"></i></span>
                <input type="text" id="stockSearch" class="form-control bg-light border-start-0 rounded-end-pill" placeholder="Filter items...">
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="lowStockTable">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase fs-xs fw-bold text-muted">Item Name</th>
                            <th class="py-3 text-uppercase fs-xs fw-bold text-muted">Category</th>
                            <th class="py-3 text-uppercase fs-xs fw-bold text-muted text-center">Current Stock</th>
                            <th class="py-3 text-uppercase fs-xs fw-bold text-muted text-center">Min Threshold</th>
                            <th class="py-3 text-uppercase fs-xs fw-bold text-muted">Status</th>
                            <th class="py-3 text-uppercase fs-xs fw-bold text-muted">Supplier</th>
                            <th class="pe-4 py-3 text-end text-uppercase fs-xs fw-bold text-muted">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                var pct = item.MinStockLevel > 0 ? (double)item.Quantity / item.MinStockLevel * 100 : 0;
                                
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded-3 p-2 me-3">
                                                <i class="bi bi-box-seam fs-5 text-primary"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@item.Name</div>
                                                <small class="text-muted">ID: #INV-@item.Id.ToString("D4")</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-primary rounded-pill px-3">@item.Category</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="fw-bold @(item.Quantity == 0 ? "text-danger" : "text-dark")">@item.Quantity</div>
                                        <div class="progress mt-1 mx-auto" style="height: 4px; width: 60px;">
                                            <div class="progress-bar @(item.Quantity == 0 ? "bg-danger" : "bg-warning")" role="progressbar" style="width: @Math.Min(pct, 100)%"></div>
                                        </div>
                                    </td>
                                    <td class="text-center text-muted fw-bold">@item.MinStockLevel</td>
                                    <td>
                                        @if (item.Quantity == 0)
                                        {
                                            <span class="badge rounded-pill bg-danger px-3"><i class="bi bi-x-circle me-1"></i> Out of Stock</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-warning text-dark px-3"><i class="bi bi-exclamation-circle me-1"></i> Low Stock</span>
                                        }
                                    </td>
                                    <td class="text-muted">@item.Supplier</td>
                                    <td class="pe-4 text-end">
                                        <div class="btn-group">
                                            <a href="/Inventories/Edit/@item.Id" class="btn btn-sm btn-light rounded-pill px-3 me-2 border">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a href="/Inventories/Details/@item.Id" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">
                                                Restock
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted italic">
                                    <i class="bi bi-check-circle fs-1 mb-3 d-block text-success opacity-50"></i>
                                    All inventory levels are currently healthy.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .fs-xs { font-size: 0.75rem; letter-spacing: 0.05em; }
    .rounded-4 { border-radius: 1rem !important; }
    .table-hover tbody tr:hover { background-color: rgba(78, 115, 223, 0.02); }
</style>

@section Scripts {
    <script>
        document.getElementById('stockSearch').addEventListener('keyup', function() {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll('#lowStockTable tbody tr');
            
            rows.forEach(row => {
                let text = row.innerText.toLowerCase();
                row.style.display = text.includes(filter) ? '' : 'none';
            });
        });
    </script>
}
