@model LouietexERP.Models.Inventory

@{
    ViewData["Title"] = "Remove Inventory";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-danger py-4 text-center">
                    <div class="bg-white bg-opacity-25 rounded-circle d-inline-flex align-items-center justify-content-center p-3 mb-2 shadow-sm">
                        <i class="bi bi-trash fs-1 text-white"></i>
                    </div>
                    <h4 class="text-white fw-bold mb-0">Confirm Deletion</h4>
                </div>
                <div class="card-body p-4 p-md-5 text-center">
                    <h3 class="fw-bold text-dark mb-3">Are you sure?</h3>
                    <p class="text-muted mb-4">
                        You are about to remove <span class="text-danger fw-bold">@Model.Name</span> from the inventory. 
                        This action cannot be undone and will affect stock calculations.
                    </p>

                    <div class="bg-light rounded-4 p-4 mb-4 text-start">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Material Name:</span>
                            <span class="fw-bold text-dark">@Model.Name</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Category:</span>
                            <span class="fw-bold text-dark">@Model.Category</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Current Stock:</span>
                            <span class="fw-bold text-dark">@Model.Quantity Units</span>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-3 flex-sm-row d-sm-flex justify-content-center">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5 shadow">
                                <i class="bi bi-trash-fill me-2"></i> Delete Permanently
                            </button>
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-5 border shadow-sm">
                                No, Keep It
                            </a>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light py-3 text-center border-0">
                    <small class="text-muted italic"><i class="bi bi-info-circle me-1"></i> Removing items may impact production reports.</small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1.25rem !important; }
</style>
