@model LouietexERP.Models.Inventory

@{
    ViewData["Title"] = "Inventory Details";
    bool isLow = Model.Quantity <= Model.MinStockLevel;
    bool isOut = Model.Quantity == 0;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header -->
            <div class="d-flex align-items-center mb-4">
                <a href="/Inventories/Index" class="btn btn-light rounded-circle p-3 me-3 shadow-sm border">
                    <i class="bi bi-arrow-left fs-5"></i>
                </a>
                <div class="flex-grow-1">
                    <h2 class="fw-bold text-dark mb-0">Inventory Summary</h2>
                    <p class="text-muted mb-0">Detailed stock analysis for item ID: #INV-@Model.Id.ToString("D4")</p>
                </div>
                <div class="d-none d-md-block">
                    <a href="/Inventories/Edit/@Model.Id" class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-pencil me-2"></i> Edit Item
                    </a>
                </div>
            </div>

            <div class="row g-4">
                <!-- Main Card -->
                <div class="col-xl-8 col-lg-7">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4 p-md-5">
                            <div class="d-flex align-items-start justify-content-between mb-4">
                                <div>
                                    <h1 class="fw-bold text-dark mb-2">@Model.Name</h1>
                                    <span class="badge bg-light text-primary rounded-pill px-3 py-2 fs-6">@Model.Category</span>
                                </div>
                                <div class="bg-primary bg-opacity-10 rounded-4 p-3 text-primary">
                                    <i class="bi bi-box-seam fs-1"></i>
                                </div>
                            </div>

                            <hr class="my-4 opacity-10">

                            <div class="row g-4 mb-4">
                                <div class="col-sm-6">
                                    <div class="p-3 bg-light rounded-4 border-start border-4 border-primary">
                                        <h6 class="text-muted small text-uppercase mb-1">Current Stock</h6>
                                        <h3 class="fw-bold text-dark mb-0">@Model.Quantity Units</h3>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="p-3 bg-light rounded-4 border-start border-4 border-warning">
                                        <h6 class="text-muted small text-uppercase mb-1">Safety Threshold</h6>
                                        <h3 class="fw-bold text-dark mb-0">@Model.MinStockLevel Units</h3>
                                    </div>
                                </div>
                            </div>

                            <div class="info-grid">
                                <div class="info-item mb-3">
                                    <span class="text-muted me-3" style="width: 120px; display: inline-block;">Supplier:</span>
                                    <span class="fw-bold text-dark">@Model.Supplier</span>
                                </div>
                                <div class="info-item mb-3">
                                    <span class="text-muted me-3" style="width: 120px; display: inline-block;">Material Type:</span>
                                    <span class="fw-bold text-dark">@Model.Category</span>
                                </div>
                                <div class="info-item">
                                    <span class="text-muted me-3" style="width: 120px; display: inline-block;">Status:</span>
                                    @if (isOut) {
                                        <span class="badge bg-danger rounded-pill px-3">Out of Stock</span>
                                    } else if (isLow) {
                                        <span class="badge bg-warning text-dark rounded-pill px-3">Low Stock Warning</span>
                                    } else {
                                        <span class="badge bg-success rounded-pill px-3">Stock Healthy</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Health & Actions Sidebar -->
                <div class="col-xl-4 col-lg-5">
                    <div class="card border-0 shadow-sm rounded-4 mb-4">
                        <div class="card-body p-4 text-center">
                            <h6 class="fw-bold text-dark text-uppercase small mb-4">Stock Health Score</h6>
                            
                            @{
                                double healthPct = Model.MinStockLevel > 0 ? (double)Model.Quantity / (Model.MinStockLevel * 2) * 100 : 100;
                                healthPct = Math.Min(healthPct, 100);
                                string healthColor = healthPct > 80 ? "#1cc88a" : healthPct > 40 ? "#f6c23e" : "#e74a3b";
                            }
                            
                            <div class="position-relative d-inline-block mb-3">
                                <svg width="150" height="150" viewBox="0 0 100 100">
                                    <circle cx="50" cy="50" r="45" fill="none" stroke="#f0f0f5" stroke-width="8" />
                                    <circle cx="50" cy="50" r="45" fill="none" stroke="@healthColor" stroke-width="8" 
                                            stroke-dasharray="283" stroke-dashoffset="@(283 - (283 * healthPct / 100))" 
                                            transform="rotate(-90 50 50)" />
                                </svg>
                                <div class="position-absolute top-50 start-50 translate-middle">
                                    <h3 class="fw-bold mb-0">@((int)healthPct)%</h3>
                                </div>
                            </div>
                            
                            <p class="text-muted small px-3">Health score is calculated relative to your minimum stock threshold.</p>
                        </div>
                    </div>

                    @if (isLow)
                    {
                        <div class="card border-0 bg-danger bg-opacity-10 rounded-4 mb-4">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center text-danger mb-2">
                                    <i class="bi bi-exclamation-octagon-fill fs-4 me-2"></i>
                                    <h6 class="fw-bold mb-0">Critical Alert</h6>
                                </div>
                                <p class="text-danger small mb-0">
                                    Stock level is @(isOut ? "completely depleted" : "below minimum threshold"). Please initiate a restock request with @Model.Supplier.
                                </p>
                            </div>
                        </div>
                    }

                    <div class="d-grid gap-2 d-md-none">
                        <a href="/Inventories/Edit/@Model.Id" class="btn btn-primary btn-lg rounded-pill">Edit Item</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1.25rem !important; }
</style>
