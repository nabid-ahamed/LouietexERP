@model LouietexERP.Models.Inventory

@{
    ViewData["Title"] = "Add New Material";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex align-items-center mb-4">
                <a href="/Inventories/Index" class="btn btn-light rounded-circle p-3 me-3 shadow-sm border">
                    <i class="bi bi-arrow-left fs-5"></i>
                </a>
                <div>
                    <h2 class="fw-bold text-dark mb-0">Add New Material</h2>
                    <p class="text-muted mb-0">Register a new item in the warehouse inventory.</p>
                </div>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary py-4 text-center">
                    <div class="bg-white bg-opacity-25 rounded-circle d-inline-flex align-items-center justify-content-center p-3 mb-2">
                        <i class="bi bi-box-seam fs-2 text-white"></i>
                    </div>
                    <h5 class="text-white fw-bold mb-0">Inventory Details</h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        
                        <div class="row g-4">
                            <!-- Name -->
                            <div class="col-md-12">
                                <label asp-for="Name" class="form-label fw-bold text-dark mb-2"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-tag text-primary"></i></span>
                                    <input asp-for="Name" class="form-control bg-light border-0 py-3" placeholder="e.g. Cotton Blue XL" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- Category -->
                            <div class="col-md-6">
                                <label asp-for="Category" class="form-label fw-bold text-dark mb-2"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-grid text-primary"></i></span>
                                    <select asp-for="Category" class="form-select bg-light border-0 py-3">
                                        <option value="">Select Category</option>
                                        <option value="Fabric">Fabric</option>
                                        <option value="Accessories">Accessories</option>
                                        <option value="Thread">Thread</option>
                                        <option value="Buttons">Buttons</option>
                                        <option value="Zippers">Zippers</option>
                                        <option value="Packaging">Packaging</option>
                                    </select>
                                </div>
                                <span asp-validation-for="Category" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- Supplier -->
                            <div class="col-md-6">
                                <label asp-for="Supplier" class="form-label fw-bold text-dark mb-2"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-truck text-primary"></i></span>
                                    <input asp-for="Supplier" class="form-control bg-light border-0 py-3" placeholder="Vendor name" />
                                </div>
                                <span asp-validation-for="Supplier" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- Quantity -->
                            <div class="col-md-6">
                                <label asp-for="Quantity" class="form-label fw-bold text-dark mb-2"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-stack text-primary"></i></span>
                                    <input asp-for="Quantity" type="number" class="form-control bg-light border-0 py-3" placeholder="0" />
                                </div>
                                <span asp-validation-for="Quantity" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- Min Stock -->
                            <div class="col-md-6">
                                <label asp-for="MinStockLevel" class="form-label fw-bold text-dark mb-2"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-bell text-warning"></i></span>
                                    <input asp-for="MinStockLevel" type="number" class="form-control bg-light border-0 py-3" placeholder="Threshold" />
                                </div>
                                <span asp-validation-for="MinStockLevel" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <hr class="my-5 opacity-10">

                        <div class="d-flex flex-column flex-sm-row gap-3">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 flex-grow-1 shadow">
                                <i class="bi bi-save me-2"></i> Save Inventory
                            </button>
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-5 border shadow-sm">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1.25rem !important; }
    .form-control:focus, .form-select:focus { 
        box-shadow: none; 
        background-color: #fff !important;
        border: 1px solid #4e73df !important;
    }
    .input-group-text { min-width: 45px; justify-content: center; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
