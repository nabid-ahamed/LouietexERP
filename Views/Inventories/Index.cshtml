@model IEnumerable<LouietexERP.Models.Inventory>

@{
    ViewData["Title"] = "Inventory Management";
}

<div class="container-fluid px-4 py-4">
    <!-- Header Section -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-box-seam text-primary me-2"></i> Inventory Management
            </h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/Dashboard/Index">Dashboard</a></li>
                    <li class="breadcrumb-item active">Inventory</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <a href="/Inventories/LowStock" class="btn btn-outline-danger rounded-pill px-4 shadow-sm">
                <i class="bi bi-exclamation-triangle me-2"></i> Low Stock
            </a>
            <a href="/Inventories/Create" class="btn btn-primary rounded-pill px-4 shadow">
                <i class="bi bi-plus-lg me-2"></i> Add Material
            </a>
        </div>
    </div>

    <!-- Search & Stats Row -->
    <div class="row g-4 mb-4">
        <div class="col-xl-9 col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-3">
                    <form asp-action="Index" method="get" class="row g-2">
                        <div class="col-md-8">
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 ps-3"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" name="searchString" class="form-control bg-light border-0 py-2" placeholder="Search by name or category..." value="@ViewContext.HttpContext.Request.Query["searchString"]">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-primary w-100 rounded-3 py-2 px-4">Apply Filters</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="rounded-circle bg-white bg-opacity-25 p-3 me-3">
                        <i class="bi bi-layers fs-4"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 text-white-50 small">Total Items</h6>
                        <h4 class="mb-0 fw-bold">@Model.Count()</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Inventory Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase fs-xs fw-bold text-muted">Material / Product</th>
                            <th class="py-3 text-uppercase fs-xs fw-bold text-muted">Category</th>
                            <th class="py-3 text-uppercase fs-xs fw-bold text-muted text-center">Stock Level</th>
                            <th class="py-3 text-uppercase fs-xs fw-bold text-muted text-center">Min Threshold</th>
                            <th class="py-3 text-uppercase fs-xs fw-bold text-muted">Status</th>
                            <th class="py-3 text-uppercase fs-xs fw-bold text-muted">Supplier</th>
                            <th class="pe-4 py-3 text-end text-uppercase fs-xs fw-bold text-muted">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                bool isLow = item.Quantity <= item.MinStockLevel;
                                bool isOut = item.Quantity == 0;
                                
                                string statusBadge = isOut ? "bg-light-danger text-danger" : 
                                                    isLow ? "bg-light-warning text-warning-dark" : "bg-light-success text-success";
                                string statusText = isOut ? "Out of Stock" : isLow ? "Low Stock" : "In Stock";
                                string statusIcon = isOut ? "bi-x-circle" : isLow ? "bi-exclamation-triangle" : "bi-check-circle";

                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded-3 p-2 me-3">
                                                <i class="bi bi-box-seam fs-5 text-primary"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@item.Name</div>
                                                <small class="text-muted">#INV-@item.Id.ToString("D4")</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-primary rounded-pill px-3">@item.Category</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-bold @(isLow ? "text-danger" : "text-dark")">@item.Quantity</span>
                                    </td>
                                    <td class="text-center text-muted fw-bold">@item.MinStockLevel</td>
                                    <td>
                                        <span class="badge rounded-pill @statusBadge px-3 py-2 d-inline-flex align-items-center gap-1">
                                            <i class="bi @statusIcon"></i> @statusText
                                        </span>
                                    </td>
                                    <td class="text-muted">@item.Supplier</td>
                                    <td class="pe-4 text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a href="/Inventories/Edit/@item.Id" class="btn btn-sm btn-light border rounded-pill px-3" title="Edit">
                                                <i class="bi bi-pencil-fill text-primary"></i>
                                            </a>
                                            <a href="/Inventories/Details/@item.Id" class="btn btn-sm btn-light border rounded-pill px-3" title="Details">
                                                <i class="bi bi-eye-fill text-info"></i>
                                            </a>
                                            <a href="/Inventories/Delete/@item.Id" class="btn btn-sm btn-light border rounded-pill px-3" title="Delete">
                                                <i class="bi bi-trash-fill text-danger"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 mb-2 d-block opacity-25"></i>
                                    No inventory records found matching your search.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .fs-xs { font-size: 0.7rem; letter-spacing: 0.05em; }
    .rounded-4 { border-radius: 1rem !important; }
    .bg-light-danger { background-color: #ffeef0 !important; }
    .bg-light-warning { background-color: #fff9e6 !important; }
    .bg-light-success { background-color: #e8f9f2 !important; }
    .text-warning-dark { color: #856404 !important; }
    
    .table-hover tbody tr:hover { 
        background-color: rgba(78, 115, 223, 0.02); 
        transform: scale(1.001);
        transition: all 0.2s ease;
    }
</style>
