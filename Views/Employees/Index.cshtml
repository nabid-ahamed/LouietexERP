@model IEnumerable<LouietexERP.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="fade-in-up">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Employee Directory</h2>
            <p class="text-muted small mb-0">Manage and monitor all factory personnel</p>
        </div>
        <a asp-action="Create" class="btn-premium btn-premium-primary">
            <i class="bi bi-person-plus-fill"></i> Add New Employee
        </a>
    </div>

    <!-- Main Card -->
    <div class="erp-card">
        <div class="erp-card-header">
            <div class="d-flex align-items-center gap-3 w-100">
                <div class="flex-grow-1">
                    <form method="get" asp-action="Index" class="position-relative">
                        <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                        <input type="text" name="searchString" value="@Context.Request.Query["searchString"]" 
                               class="form-control premium-input ps-5 w-100" placeholder="Search by name, email or department..." />
                    </form>
                </div>
                <div class="d-flex gap-2">
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary dropdown-toggle premium-input" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-filter"></i> Filter
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                            <li><a class="dropdown-item" href="#">All Departments</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="#">Cutting</a></li>
                            <li><a class="dropdown-item" href="#">Sewing</a></li>
                            <li><a class="dropdown-item" href="#">Finishing</a></li>
                        </ul>
                    </div>
                    @if (User.IsInRole(SD.Role_HR) || User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_SuperAdmin))
                    {
                        <a asp-action="ExportPdf" asp-route-searchString="@Context.Request.Query["searchString"]" class="btn btn-outline-danger premium-input">
                            <i class="bi bi-file-earmark-pdf"></i> Export PDF
                        </a>
                        <button onclick="window.print()" class="btn btn-outline-primary premium-input">
                            <i class="bi bi-printer"></i> Print
                        </button>
                    }
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="erp-table">
                <thead>
                    <tr>
                        <th>Employee Details</th>
                        <th>Department</th>
                        <th>Role</th>
                        <th>Joining Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center fw-bold text-primary me-3" style="width: 40px; height: 40px; font-size: 14px;">
                                        @item.FullName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@item.FullName</div>
                                        <div class="text-muted small">@item.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-primary border border-primary-subtle px-3 py-2">
                                    @item.Department
                                </span>
                            </td>
                            <td>
                                <div class="text-dark fw-medium">@item.Role</div>
                            </td>
                            <td>
                                <div class="text-muted">@item.JoiningDate.ToString("MMM dd, yyyy")</div>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-icon action-edit" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="action-icon action-details" title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @* <a asp-action="Delete" asp-route-id="@item.Id" class="action-icon action-delete" title="Delete">
                                        <i class="bi bi-trash3"></i>
                                    </a> *@
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="p-5 text-center">
                <i class="bi bi-people text-muted display-1 opacity-25"></i>
                <p class="mt-3 text-muted">No employees found matching your criteria.</p>
            </div>
        }
    </div>
</div>
