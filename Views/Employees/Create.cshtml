@model LouietexERP.Models.Employee

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Employee</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <div class="employee-container">
            <div class="employee-container-wide">

                <h2>Create Employee</h2>
                <p class="text-muted mb-4">Add new employee information</p>

                <form method="post">

                    <div class="row">

                        <!-- LEFT SIDE -->
                        <div class="col-md-6">

                            <div class="mb-3">
                                <label>Full Name</label>
                                <input asp-for="FullName" class="form-control custom-input" />
                            </div>

                            <div class="mb-3">
                                <label>Department</label>
                                <select asp-for="Department" class="form-control custom-input">
                                    <option>Select Department</option>
                                    <option>HR</option>
                                    <option>QC</option>
                                    <option>Production</option>
                                    <option>Accounts</option>
                                    <option>Sales</option>
                                    <option>IT</option>
                                </select>
                            </div>

                        </div>

                        <!-- RIGHT SIDE -->
                        <div class="col-md-6">

                            <div class="mb-3">
                                <label>Email</label>
                                <input asp-for="Email" class="form-control custom-input" />
                            </div>

                            <div class="mb-3">
                                <label>Role</label>
                                <select asp-for="Role" class="form-control custom-input">
                                    <option>Select Role</option>
                                    <option>Admin</option>
                                    <option>Manager</option>
                                    <option>Employee</option>
                                </select>
                            </div>

                        </div>

                    </div>

                    <!-- FULL WIDTH FIELD -->
                    <div class="mb-3">
                        <label>Joining Date</label>
                        <input asp-for="JoiningDate" type="date" class="form-control custom-input" />
                    </div>

                    <!-- SUBMIT BUTTON CENTER -->
                    <div class="text-center mt-4">
                        <button type="submit" class="btn btn-primary px-5 py-2">
                            Create Employee
                        </button>
                    </div>

                    <div class="text-center mt-3">
                        <a asp-action="Index">Back to List</a>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
