@model LouietexERP.Models.Employee

@{
    ViewData["Title"] = "Delete Employee";
}

<div class="fade-in-up container" style="max-width: 600px; margin-top: 50px;">
    <div class="erp-card border-danger shadow-sm">
        <div class="card-header bg-danger bg-opacity-10 border-bottom border-danger border-opacity-25 p-4 text-center">
            <div class="rounded-circle bg-danger bg-opacity-25 d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <i class="bi bi-exclamation-triangle text-danger fs-1"></i>
            </div>
            <h3 class="fw-bold text-danger mb-1">Delete Employee?</h3>
            <p class="text-muted small mb-0">This action cannot be undone and will remove all records for this employee.</p>
        </div>
        
        <div class="card-body p-4">
            <div class="bg-light rounded-3 p-4 mb-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold me-3" style="width: 50px; height: 50px; font-size: 18px;">
                        @Model.FullName.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0">@Model.FullName</h5>
                        <div class="text-muted small">@Model.Email</div>
                    </div>
                </div>
                
                <div class="row g-3">
                    <div class="col-6">
                        <div class="text-muted small uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 1px;">DEPARTMENT</div>
                        <div class="fw-medium text-dark">@Model.Department</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 1px;">ROLE</div>
                        <div class="fw-medium text-dark">@Model.Role</div>
                    </div>
                    <div class="col-12">
                        <div class="text-muted small uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 1px;">JOINING DATE</div>
                        <div class="fw-medium text-dark">@Model.JoiningDate.ToString("MMMM dd, yyyy")</div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" class="d-flex gap-3">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn-premium btn-premium-danger flex-grow-1 justify-content-center">
                    <i class="bi bi-trash3"></i> Yes, Delete Permanent
                </button>
                <a asp-action="Index" class="btn btn-light px-4 border rounded-3 fw-bold">Cancel</a>
            </form>
        </div>
    </div>
</div>
