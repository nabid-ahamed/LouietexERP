@model LouietexERP.Models.Employee

@{
    ViewData["Title"] = "Employee Profile";
    var yearsOfTenure = (DateTime.Now - Model.JoiningDate).Days / 365.0;
}

<div class="fade-in-up container" style="max-width: 1000px;">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Employees</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Profile</li>
                </ol>
            </nav>
            <h2 class="fw-bold text-dark mb-0">Employee Profile</h2>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary px-4 rounded-3 fw-bold">
                <i class="bi bi-pencil-square me-2"></i>Edit Profile
            </a>
            <a asp-action="Index" class="btn btn-light px-4 border rounded-3 fw-bold text-muted">
                <i class="bi bi-arrow-left me-2"></i>Back to Directory
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column: Summary Card -->
        <div class="col-lg-4">
            <div class="erp-card text-center p-4">
                <div class="position-relative d-inline-block mb-4">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center shadow-lg mx-auto" 
                         style="width: 120px; height: 120px; font-size: 48px; font-weight: 700; border: 5px solid rgba(78, 115, 223, 0.1);">
                        @Model.FullName.Substring(0, 1).ToUpper()
                    </div>
                    <span class="position-absolute bottom-0 end-0 bg-success border border-white border-3 rounded-circle p-2" title="Active Account"></span>
                </div>
                
                <h4 class="fw-bold text-dark mb-1">@Model.FullName</h4>
                <p class="text-primary fw-semibold mb-3">@Model.Role</p>
                
                <div class="badge bg-light text-primary border border-primary-subtle px-4 py-2 rounded-pill mb-4">
                    @Model.Department Department
                </div>

                <hr class="opacity-10 my-4">

                <div class="text-start">
                    <div class="d-flex align-items-center mb-3">
                        <div class="action-icon bg-light text-primary me-3" style="width: 35px; height: 35px;">
                            <i class="bi bi-envelope"></i>
                        </div>
                        <div class="text-truncate">
                            <div class="text-muted small">Email Address</div>
                            <div class="fw-medium text-dark">@Model.Email</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center mb-0">
                        <div class="action-icon bg-light text-primary me-3" style="width: 35px; height: 35px;">
                            <i class="bi bi-calendar-check"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Joined Date</div>
                            <div class="fw-medium text-dark">@Model.JoiningDate.ToString("MMMM dd, yyyy")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Details & Stats -->
        <div class="col-lg-8">
            <!-- Tenure Stats Card -->
            <div class="erp-card mb-4 p-4">
                <h5 class="fw-bold text-dark mb-4">Tenure Statistics</h5>
                <div class="row g-4 text-center">
                    <div class="col-md-4">
                        <div class="bg-light rounded-4 p-3 border border-white shadow-sm">
                            <div class="text-primary h3 fw-bold mb-1">@yearsOfTenure.ToString("N1")</div>
                            <div class="text-muted small uppercase fw-bold" style="font-size: 0.65rem;">YEARS SERVICE</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-light rounded-4 p-3 border border-white shadow-sm">
                            <div class="text-success h3 fw-bold mb-1">@((int)(yearsOfTenure * 12))</div>
                            <div class="text-muted small uppercase fw-bold" style="font-size: 0.65rem;">TOTAL MONTHS</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-light rounded-4 p-3 border border-white shadow-sm">
                            <div class="text-info h3 fw-bold mb-1">100%</div>
                            <div class="text-muted small uppercase fw-bold" style="font-size: 0.65rem;">ATTENDANCE RATE</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Professional Info -->
            <div class="erp-card p-4">
                <h5 class="fw-bold text-dark mb-4 border-bottom pb-3">Professional Information</h5>
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="text-muted small uppercase fw-bold mb-1 d-block" style="font-size: 0.65rem; letter-spacing: 1px;">EMPLOYEE ID</label>
                        <div class="p-3 bg-light rounded-3 fw-bold text-dark">EMP-@Model.Id.ToString("D5")</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small uppercase fw-bold mb-1 d-block" style="font-size: 0.65rem; letter-spacing: 1px;">WORK STATUS</label>
                        <div class="p-3 bg-light rounded-3 fw-bold text-success"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>Full-Time Permanent</div>
                    </div>
                    <div class="col-md-12">
                        <label class="text-muted small uppercase fw-bold mb-1 d-block" style="font-size: 0.65rem; letter-spacing: 1px;">REPORTING MANAGER</label>
                        <div class="p-3 bg-light rounded-3 text-dark">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width: 30px; height: 30px; font-size: 12px;">S</div>
                                <span>Md. Shafiqul Haque (Production Manager)</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-4 pt-4 border-top">
                    <p class="text-muted small"><i class="bi bi-info-circle me-1"></i> Data last synchronized on @DateTime.Now.ToString("dd MMM yyyy HH:mm")</p>
                </div>
            </div>
        </div>
    </div>
</div>
