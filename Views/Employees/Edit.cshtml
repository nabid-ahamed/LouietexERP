@model LouietexERP.Models.Employee

@{
    ViewData["Title"] = "Edit Employee";
}

<div class="fade-in-up container" style="max-width: 850px;">
    <!-- Header -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h2 class="fw-bold text-dark mb-0">Edit Employee Profile</h2>
            <p class="text-muted small mb-0">Modify professional details and update system roles</p>
        </div>
    </div>

    <div class="erp-card p-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
            <input type="hidden" asp-for="Id" />

            <div class="row g-4">
                <!-- Profile Identity Section -->
                <div class="col-md-12">
                    <div class="d-flex align-items-center bg-light rounded-4 p-3 mb-2 border border-white">
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold me-3 shadow-sm" style="width: 55px; height: 55px; font-size: 20px;">
                            @Model.FullName.Substring(0, 1).ToUpper()
                        </div>
                        <div>
                            <div class="text-muted small uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 1px;">CURRENTLY EDITING</div>
                            <div class="h5 fw-bold text-dark mb-0">@Model.FullName</div>
                        </div>
                        <div class="ms-auto text-end">
                            <div class="text-muted small">Employee ID</div>
                            <div class="fw-bold text-primary">#EMP-@Model.Id.ToString("D5")</div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label fw-bold text-dark">Full Legal Name</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-person-badge"></i></span>
                        <input asp-for="FullName" class="form-control premium-input border-start-0" placeholder="Update full name" />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-bold text-dark">Work Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope-at"></i></span>
                        <input asp-for="Email" class="form-control premium-input border-start-0" placeholder="Update email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Department" class="form-label fw-bold text-dark">Department Assignment</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-building"></i></span>
                        <select asp-for="Department" class="form-select premium-input border-start-0">
                            <option value="">Select Department</option>
                            <option>Cutting</option>
                            <option>Sewing</option>
                            <option>Finishing</option>
                            <option>QC</option>
                            <option>HR</option>
                            <option>Production</option>
                            <option>Merchandising</option>
                            <option>Packing</option>
                            <option>Embroidery</option>
                        </select>
                    </div>
                    <span asp-validation-for="Department" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Role" class="form-label fw-bold text-dark">System Role</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-lock"></i></span>
                        <select asp-for="Role" class="form-select premium-input border-start-0">
                            <option value="">Select Role</option>
                            <option>Operator</option>
                            <option>Supervisor</option>
                            <option>Manager</option>
                            <option>QC Officer</option>
                            <option>Helper</option>
                            <option>Line Chief</option>
                            <option>HR Officer</option>
                            <option>Merchandiser</option>
                        </select>
                    </div>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="JoiningDate" class="form-label fw-bold text-dark">Date of Joining</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-calendar-check"></i></span>
                        <input asp-for="JoiningDate" type="date" class="form-control premium-input border-start-0" />
                    </div>
                    <span asp-validation-for="JoiningDate" class="text-danger small"></span>
                </div>
            </div>

            <div class="mt-5 d-flex gap-3">
                <button type="submit" class="btn-premium btn-premium-primary flex-grow-1 justify-content-center py-3 shadow-sm">
                    <i class="bi bi-cloud-upload-fill"></i> Update Employee Profile
                </button>
                <a asp-action="Index" class="btn btn-light px-4 border py-3 rounded-3 fw-bold text-muted">Discard Changes</a>
            </div>
        </form>
    </div>

    <div class="mt-4 text-center">
        <p class="text-muted small"><i class="bi bi-lock-fill me-1"></i> Information updated here will reflect across all production and payroll modules instantly.</p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
