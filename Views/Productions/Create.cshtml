@model LouietexERP.Models.Production

@{
    ViewData["Title"] = "Create Production";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-primary text-white rounded-top-4 p-4">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-gear-wide-connected fs-4 me-2"></i>
                        <h5 class="mb-0 fw-bold">New Production Run</h5>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="OrderId" class="form-label fw-bold">Linked Order <span class="text-danger">*</span></label>
                                <select asp-for="OrderId" class="form-select" asp-items="ViewBag.OrderId">
                                    <option value="">-- Select Order --</option>
                                </select>
                                <span asp-validation-for="OrderId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="LineNumber" class="form-label fw-bold">Production Line <span class="text-danger">*</span></label>
                                <input asp-for="LineNumber" class="form-control" placeholder="e.g. Line-01" />
                                <span asp-validation-for="LineNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Supervisor" class="form-label fw-bold">Supervisor</label>
                                <input asp-for="Supervisor" class="form-control" placeholder="e.g. John Doe" />
                                <span asp-validation-for="Supervisor" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="TargetQuantity" class="form-label fw-bold">Target Quantity <span class="text-danger">*</span></label>
                                <input asp-for="TargetQuantity" class="form-control" />
                                <span asp-validation-for="TargetQuantity" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ActualOutput" class="form-label fw-bold">Actual Output</label>
                                <input asp-for="ActualOutput" class="form-control" value="0" />
                                <span asp-validation-for="ActualOutput" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label fw-bold">Start Date</label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label fw-bold">Status</label>
                                <select asp-for="Status" class="form-select">
                                    <option value="Pending">Pending</option>
                                    <option value="Running">Running</option>
                                    <option value="Completed">Completed</option>
                                    <option value="Delayed">Delayed</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-save me-2"></i> Create Run
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
