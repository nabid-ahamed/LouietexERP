@model List<LouietexERP.Models.ApplicationUser>

<div class="container mt-4">
    <h4><i class="bi bi-image me-2"></i> Pending Profile Pictures</h4>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info">No pending profile pictures.</div>
    }
    else
    {
        <div class="row">
            @foreach (var user in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="card shadow-sm text-center p-3">
                        <img src="@user.PendingProfilePicturePath"
                             class="rounded-circle mx-auto mb-2"
                             style="width:80px; height:80px; object-fit:cover;" />
                        <p class="fw-semibold mb-1">@user.FullName</p>
                        <small class="text-muted">@user.Email</small>

                        <div class="d-flex gap-2 mt-3 justify-content-center">
                            <form method="post" asp-controller="UserManagement"
                                  asp-action="ApprovePicture" asp-route-id="@user.Id">
                                <button class="btn btn-sm btn-success">
                                    <i class="bi bi-check"></i> Approve
                                </button>
                            </form>
                            <form method="post" asp-controller="UserManagement"
                                  asp-action="RejectPicture" asp-route-id="@user.Id">
                                <button class="btn btn-sm btn-danger">
                                    <i class="bi bi-x"></i> Reject
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>