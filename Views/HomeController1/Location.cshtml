@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Location - Louietex</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
            body {
                background-color: #f2f2f2;
            }

            /* HEADER */
            .logo-section {
                background: white;
                padding: 20px 40px;
            }

                .logo-section img {
                    height: 60px;
                }

            /* MENU */
            .menu-bar {
                background: #e6e6e6;
                padding-left: 40px;
                display: flex;
            }

                .menu-bar a {
                    display: block;
                    padding: 15px 25px;
                    text-decoration: none;
                    color: #555;
                    transition: 0.3s;
                }

                    .menu-bar a.active {
                        background: #3fc1b6;
                        color: white;
                    }

                    .menu-bar a:hover {
                        background: #3fc1b6;
                        color: white;
                    }

            /* BANNER */
            .banner {
                background: white;
                text-align: center;
                padding: 40px 0;
            }

                .banner img {
                    width: 70%;
                }

            /* LOCATION */
            .location-section {
                padding: 60px 100px;
                background: #f5f5f5;
            }

            .location-content {
                display: flex;
                justify-content: space-around;
                align-items: center;
            }

            .location-text {
                max-width: 300px;
            }

            .location-map iframe {
                width: 400px;
                height: 250px;
                border: 0;
            }

            /* FOOTER */
            .footer-section {
                background: #333;
                color: white;
                text-align: center;
                padding: 60px 20px;
            }

            .footer-content {
                display: flex;
                justify-content: space-around;
                margin-top: 40px;
            }

            .footer-line {
                width: 60%;
                height: 1px;
                background: #777;
                margin: 40px auto;
            }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="logo-section">
        <img src="~/images/logo.png" />
    </div>

    <!-- MENU -->
    <div class="menu-bar">
        <a href="/HomeController1/Landing">ABOUT</a>
        <a href="/HomeController1/Contact">CONTACT</a>
        <a class="active" href="/HomeController1/Location">LOCATION</a>
          <!-- LOGIN BUTTON -->
    <a class="login-btn" href="/Identity/Account/Login">LOGIN</a>
    </div>

    <!-- BANNER -->
    <div class="banner">
        <img src="~/images/banner.jpg" />
    </div>

    <!-- LOCATION CONTENT -->
    <div class="location-section">

        <h3 class="text-center mb-5">Location</h3>

        <div class="location-content">

            <div class="location-text">
                <p><strong>LOUIETEX MANUFACTURING LTD.</strong></p>
                <p>Factory:</p>
                <p>Mazura, Shonda, Sharifpur</p>
                <p>P.O: National University</p>
                <p>P.S & Dist: Gazipur, Bangladesh</p>

                <br />

                <p><strong>Head Office:</strong></p>
                <p>House#106, Northern Road</p>
                <p>Dhanmondi</p>
                <p>Dist: Dhaka, Bangladesh</p>
            </div>

            <div class="location-map">
                <iframe src="https://www.google.com/maps?q=National+University+Gazipur&output=embed">
                </iframe>
            </div>

        </div>

    </div>

    <!-- FOOTER -->
    <div class="footer-section">
        <h3>Get In Touch With Us</h3>

        <div class="footer-content">
            <div>
                <p>Maleker Bari, Shonda, Sharifpur</p>
                <p>Gazipur, Bangladesh</p>
            </div>

            <div>
                <p>Email: nabidahamed18@gmail.com</p>
                <p>Cell: +8801766833432</p>
            </div>
        </div>

        <div class="footer-line"></div>

        <p class="copyright">
            © @DateTime.Now.Year Louietex |Nabid Ahamed Noushad. All rights reserved
        </p>
    </div>

</body>
</html>