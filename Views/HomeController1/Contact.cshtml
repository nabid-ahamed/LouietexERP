@{
    ViewData["Title"] = "Contact";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Contact - Louietex</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
            body {
                background-color: #f2f2f2;
            }

            /* HEADER */
            .logo-section {
                background: white;
                padding: 20px 40px;
            }

                .logo-section img {
                    height: 60px;
                }

            /* MENU */
            .menu-bar {
                background: #e6e6e6;
                padding-left: 40px;
                display: flex;
            }

                .menu-bar a {
                    display: block;
                    padding: 15px 25px;
                    text-decoration: none;
                    color: #555;
                    transition: 0.3s;
                }

                    .menu-bar a.active {
                        background: #3fc1b6;
                        color: white;
                    }

                    .menu-bar a:hover {
                        background: #3fc1b6;
                        color: white;
                    }
            /* BANNER */
            .banner {
                background: white;
                text-align: center;
                padding: 40px 0;
            }

                .banner img {
                    width: 70%;
                }
            /* CONTACT SECTION */
            .contact-section {
                text-align: center;
                padding: 60px 100px;
                background: #f5f5f5;
            }

            .contact-persons {
                display: flex;
                justify-content: space-around;
                margin-top: 40px;
            }

            .person h5 {
                font-weight: 600;
            }

            .person p {
                margin: 5px 0;
                color: #555;
            }

            .email {
                color: #3fc1b6;
                border-bottom: 2px solid #3fc1b6;
                display: inline-block;
                padding-bottom: 5px;
            }

            /* FORM */
            .form-box {
                width: 40%;
                margin: 40px auto;
            }

                .form-box input,
                .form-box textarea {
                    width: 100%;
                    margin-bottom: 15px;
                    padding: 10px;
                    border: 1px solid #ccc;
                }

                .form-box textarea {
                    height: 120px;
                }

                .form-box button {
                    width: 100%;
                    background: #e74c3c;
                    color: white;
                    border: none;
                    padding: 12px;
                }

            /* FOOTER SECTION */
            .footer-section {
                background: #333;
                color: white;
                text-align: center;
                padding: 60px 20px;
            }

            .footer-content {
                display: flex;
                justify-content: space-around;
                margin-top: 40px;
            }

            .footer-item {
                max-width: 300px;
            }

                .footer-item p {
                    margin-top: 10px;
                    line-height: 1.6;
                }

            .icon {
                font-size: 30px;
            }

            .footer-line {
                width: 60%;
                height: 1px;
                background: #777;
                margin: 40px auto;
            }

            .copyright {
                font-size: 14px;
                color: #ccc;
            }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="logo-section">
        <img src="~/images/logo.png" />
    </div>

    <!-- MENU -->
    <div class="menu-bar">
        <a href="/HomeController1/Landing">ABOUT</a>
        <a class="active" href="/HomeController1/Contact">CONTACT</a>
        <a href="/HomeController1/Location">LOCATION</a>
         <!-- LOGIN BUTTON -->
            <a class="login-btn" href="/Identity/Account/Login">LOGIN</a>
    </div>
    <!-- BANNER -->
    <div class="banner">
        <img src="~/images/banner.jpg" />
    </div>

    <!-- CONTACT CONTENT -->
    <div class="contact-section">

        <h3>CONTACT PERSON</h3>

        <div class="contact-persons">
            <div class="person">
                <h5>RAJESH SETHI</h5>
                <p>Managing Director</p>
                <p class="email">vicky@louietex-bd.com</p>
            </div>

            <div class="person">
                <h5>SUNIL CHAMOLI</h5>
                <p>Executive Director</p>
                <p class="email">sunil@louietex-bd.com</p>
            </div>

            <div class="person">
                <h5>RUCHIRA DASSANAYAKE</h5>
                <p>Head of Design</p>
                <p class="email">ruchira@louietex-bd.com</p>
            </div>
        </div>

        <h3 class="mt-5">Send a message</h3>

        <div class="form-box">
            <input type="text" placeholder="Name" />
            <input type="email" placeholder="Email" />
            <textarea placeholder="Message"></textarea>
            <button>SEND</button>
        </div>

    </div>

    <!-- FOOTER -->
    <div class="footer-section">
        <h3>Get In Touch With Us</h3>

        <div class="footer-content">

            <div class="footer-item">
                <div class="icon">📍</div>
                <p>
                    Maleker Bari, Shonda, Sharifpur <br />
                    National University, Gazipur-1704 <br />
                    Bangladesh
                </p>
            </div>

            <div class="footer-item">
                <div class="icon">✉️</div>
                <p>
                    Email: sunil@louietex-bd.com <br />
                    Cell: +8801713069578
                </p>
            </div>

        </div>

        <div class="footer-line"></div>

        <p class="copyright">
            © @DateTime.Now.Year Louietex |Nabid Ahamed Noushad. All rights reserved
        </p>
    </div>

</body>
</html>