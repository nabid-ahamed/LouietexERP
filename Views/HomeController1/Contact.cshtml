@{
    ViewData["Title"] = "Contact";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Contact - Louietex</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
            body {
                background-color: #f2f2f2;
            }

            /* HEADER */
            .logo-section {
                background: white;
                padding: 20px 40px;
            }

                .logo-section img {
                    height: 60px;
                }

            /* MENU */
            .menu-bar {
                background: #e6e6e6;
                padding-left: 40px;
                display: flex;
                align-items: center;
            }

                .menu-bar a {
                    display: block;
                    padding: 15px 25px;
                    text-decoration: none;
                    color: #555;
                }

                    .menu-bar a.active,
                    .menu-bar a:hover {
                        background: #3fc1b6;
                        color: white;
                    }

          

            /* BANNER */
            .banner {
                background: white;
                text-align: center;
                padding: 40px 0;
            }

                .banner img {
                    width: 70%;
                }

            /* CONTACT SECTION */
            .contact-section {
                text-align: center;
                padding: 60px 100px;
                background: #f5f5f5;
            }

            .contact-persons {
                display: flex;
                justify-content: space-around;
                margin-top: 40px;
            }

            .person h5 {
                font-weight: 600;
            }

            .person p {
                margin: 5px 0;
                color: #555;
            }

            .email {
                color: #3fc1b6;
                border-bottom: 2px solid #3fc1b6;
                display: inline-block;
            }

            /* FORM */
            .form-box {
                max-width: 500px;
                width: 100%;
                margin: 40px auto;
            }

            .input-box {
                display: flex;
                gap: 15px;
                margin-bottom: 15px;
            }

                .input-box input {
                    width: 100%;
                    padding: 12px;
                    border: 1px solid #ccc;
                }

            textarea {
                width: 100%;
                padding: 12px;
                border: 1px solid #ccc;
                margin-bottom: 15px;
            }

            .btn-submit {
                width: 100%;
                background: #e74c3c;
                color: white;
                border: none;
                padding: 12px;
                font-weight: bold;
                cursor: pointer;
            }

            /* ✅ FIX: hidden initially */
            #form-status {
                margin-top: 15px;
                color: green;
                display: none;
            }

            /* FOOTER */
            .footer-section {
                background: #333;
                color: white;
                text-align: center;
                padding: 60px 20px;
            }

            .footer-content {
                display: flex;
                justify-content: space-around;
                margin-top: 40px;
            }

            .footer-item {
                max-width: 300px;
            }

                .footer-item p {
                    margin-top: 10px;
                    line-height: 1.6;
                }

            .icon {
                font-size: 30px;
            }

            .footer-line {
                width: 60%;
                height: 1px;
                background: #777;
                margin: 40px auto;
            }

            .copyright {
                font-size: 14px;
                color: #ccc;
            }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="logo-section">
        <img src="~/images/logo.png" />
    </div>

    <!-- MENU -->
    <div class="menu-bar">
        <a href="/HomeController1/Landing">ABOUT</a>
        <a class="active" href="/HomeController1/Contact">CONTACT</a>
        <a href="/HomeController1/Location">LOCATION</a>
        <a class="login-btn" href="/Identity/Account/Login">LOGIN</a>
    </div>

    <!-- BANNER -->
    <div class="banner">
        <img src="~/images/banner.jpg" />
    </div>

    <!-- CONTACT CONTENT -->
    <div class="contact-section">

        <h3>CONTACT PERSON</h3>

        <div class="contact-persons">
            <div class="person">
                <h5>RAJESH SETHI</h5>
                <p>Managing Director</p>
                <p class="email">vicky@louietex-bd.com</p>
            </div>

            <div class="person">
                <h5>SUNIL CHAMOLI</h5>
                <p>Executive Director</p>
                <p class="email">sunil@louietex-bd.com</p>
            </div>

            <div class="person">
                <h5>RUCHIRA DASSANAYAKE</h5>
                <p>Head of Design</p>
                <p class="email">ruchira@louietex-bd.com</p>
            </div>
        </div>

        <h3 class="mt-5">Send a message</h3>

        <div class="form-box">
            <form id="contact-form"
                  action="https://formspree.io/f/xjgejwbl"
                  method="POST">

                <!-- ✅ FIXED -->
                <input type="hidden" name="_subject" value="New message from Louietex ERP">
                <input type="hidden" name="source" value="This message is coming from Louietex ERP">

                <div class="input-box">
                    <input type="text" name="name" placeholder="Your Name" required>
                    <input type="email" name="email" placeholder="Your Email" required>
                </div>

                <div class="input-box">
                    <input type="tel" name="phone" placeholder="Phone Number (Optional)">
                </div>

                <textarea name="message" rows="6" placeholder="Your Message" required></textarea>

                <input type="text" name="_gotcha" style="display:none">

                <button type="submit" class="btn-submit">Send Message</button>
            </form>

            <p id="form-status">✅ Message sent successfully!</p>
        </div>

    </div>

    <!-- FOOTER -->
    <div class="footer-section">
        <h3>Get In Touch With Us</h3>

        <div class="footer-content">
            <div class="footer-item">
                <div class="icon">📍</div>
                <p>Gazipur, Bangladesh</p>
            </div>

            <div class="footer-item">
                <div class="icon">✉️</div>
                <p>Email: sunil@louietex-bd.com</p>
            </div>
        </div>

        <div class="footer-line"></div>

        <p class="copyright">
            © @DateTime.Now.Year Louietex | Nabid Ahamed Noushad
        </p>
    </div>

    <script>
            const form = document.getElementById("contact-form");
            const status = document.getElementById("form-status");

            form.addEventListener("submit", async function (e) {
                e.preventDefault();

                const data = new FormData(form);
                const response = await fetch(form.action, {
                    method: form.method,
                    body: data,
                    headers: { 'Accept': 'application/json' }
                });

                if (response.ok) {
                    status.style.display = "block";
                    form.reset();
                }
            });
    </script>

</body>
</html>