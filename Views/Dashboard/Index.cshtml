@model LouietexERP.Models.DashboardViewModel

<div class="container mt-4">

    <!-- HEADER + BUTTONS IN ONE ROW -->
    <div class="d-flex align-items-center gap-3 mb-4">

        <!-- DASHBOARD BANNER -->
        <div class="dashboard-header d-flex justify-content-between align-items-center p-4 flex-grow-1">

            <!-- LEFT -->
            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-speedometer2 fs-2 text-white"></i>
                <h2 class="text-white mb-0">Dashboard</h2>
            </div>

            <!-- RIGHT (TIME) -->
            <div class="time-pill">
                <i class="bi bi-calendar-event"></i>
                <span id="live-clock"></span>
            </div>

        </div>

        <!-- SUPER ADMIN BUTTONS -->
        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("SuperAdmin"))
        {
            <div class="d-flex flex-column gap-2 flex-shrink-0">

                <a class="btn btn-outline-danger fw-bold"
                       asp-controller="UserManagement"
                       asp-action="PendingApprovals">
                    Approve Users
                    @if (Model.PendingUsers > 0)
                    {
                        <span class="badge bg-danger ms-1">@Model.PendingUsers</span>
                    }
                </a>

                <a class="btn btn-outline-primary fw-bold"
                       asp-controller="UserManagement"
                       asp-action="ViewModifications">
                    Review Requests
                    @if (Model.PendingRequests > 0)
                    {
                        <span class="badge bg-primary ms-1">@Model.PendingRequests</span>
                    }
                </a>

            </div>
        }

    </div>

    @if (Model == null)
    {
        <div class="alert alert-danger text-center">
            Dashboard data not available.
        </div>
    }
    else
    {
        <!-- STATS -->
        <div class="row" style="margin-top: 2.5rem;">

            <div class="col-md-3">
                <div class="card bg-primary text-white mb-4 shadow-sm text-center">
                    <div class="card-body">
                        <h6>Total Orders</h6>
                        <h3>@Model.TotalOrders</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card bg-success text-white mb-4 shadow-sm text-center">
                    <div class="card-body">
                        <h6>Today's Output</h6>
                        <h3>@Model.TodayProduction</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card bg-warning text-dark mb-4 shadow-sm text-center">
                    <div class="card-body">
                        <h6>Low Stock</h6>
                        <h3>@Model.LowStockItems</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card bg-info text-white mb-4 shadow-sm text-center">
                    <div class="card-body">
                        <h6>Total Staff</h6>
                        <h3>@Model.TotalEmployees</h3>
                    </div>
                </div>
            </div>

        </div>

        <!-- CHARTS ROW -->
        <div class="row mt-3">

            <!-- Bar + Line Chart -->
            <div class="col-md-8">
                <div class="card shadow-sm p-4">
                    <h6 class="text-muted mb-3">Monthly Orders & Production</h6>
                    <canvas id="barChart" height="120"></canvas>
                </div>
            </div>

            <!-- Donut Chart -->
            <div class="col-md-4">
                <div class="card shadow-sm p-4">
                    <h6 class="text-muted mb-3">Top Products</h6>
                    <canvas id="donutChart" height="120"></canvas>
                </div>
            </div>

        </div>
    }

</div>

@section Scripts {

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // ===== CLOCK =====
            function updateClock() {
                const now = new Date();
                const formatted = now.toLocaleString('en-US', {
                    weekday: 'long',
                    month: 'long',
                    day: 'numeric',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit',
                    hour12: true
                });
                const el = document.getElementById("live-clock");
                if (el) el.innerText = formatted;
            }

            updateClock();
            setInterval(updateClock, 1000);

            // ===== BAR + LINE CHART (REAL DATA) =====
            try {
                const barCtx = document.getElementById('barChart');
                if (barCtx && typeof Chart !== "undefined") {

                    const monthLabels = @Html.Raw(Json.Serialize(Model.MonthLabels ?? new List<string>()));
                    const monthlyOrders = @Html.Raw(Json.Serialize(Model.MonthlyOrders ?? new List<int>()));
                    const monthlyProduction = @Html.Raw(Json.Serialize(Model.MonthlyProduction ?? new List<int>()));

                    new Chart(barCtx, {
                        type: 'bar',
                        data: {
                            labels: monthLabels,
                            datasets: [
                                {
                                    label: 'Orders',
                                    data: monthlyOrders,
                                    backgroundColor: '#5b6ee1',
                                    borderRadius: 6
                                },
                                {
                                    label: 'Production',
                                    data: monthlyProduction,
                                    type: 'line',
                                    borderColor: '#d17ddf',
                                    backgroundColor: 'transparent',
                                    tension: 0.4,
                                    pointRadius: 4
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            plugins: { legend: { position: 'top' } },
                            scales: { y: { beginAtZero: true } }
                        }
                    });
                }
            } catch (err) {
                console.log("Bar chart failed:", err);
            }

            // ===== DONUT CHART =====
            try {
                const donutCtx = document.getElementById('donutChart');
                if (donutCtx && typeof Chart !== "undefined") {
                    new Chart(donutCtx, {
                        type: 'doughnut',
                        data: {
                            labels: ['Item A', 'Item B', 'Item C'],
                            datasets: [{
                                data: [50, 30, 20],
                                backgroundColor: ['#5b6ee1', '#7d4aa3', '#d17ddf']
                            }]
                        },
                        options: {
                            responsive: true,
                            cutout: '65%',
                            plugins: { legend: { position: 'bottom' } }
                        }
                    });
                }
            } catch (err) {
                console.log("Donut chart failed:", err);
            }

        });
    </script>

}