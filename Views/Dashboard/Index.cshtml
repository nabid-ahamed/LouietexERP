@using Microsoft.AspNetCore.Identity
@using LouietexERP.Models
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Dashboard";
    
    // Roles
    var isSuperAdmin = User.IsInRole("SuperAdmin");
    var isAdmin = User.IsInRole("Admin");
    var isHR = User.IsInRole("HR");
    var isMerchandiser = User.IsInRole("Merchandiser");
    var isProductionManager = User.IsInRole("ProductionManager");
    var isQC = User.IsInRole("QC");

    // Greeting Logic
    var currentHour = DateTime.Now.Hour;
    string greeting = "Hello";
    if (currentHour >= 6 && currentHour < 12) greeting = "Good morning";
    else if (currentHour >= 12 && currentHour < 18) greeting = "Good afternoon";
    else if (currentHour >= 18 && currentHour < 24) greeting = "Good evening";

    // Chart Data serialization
    var prodLabels = Json.Serialize(ViewBag.ProdChartLabels ?? new List<string>());
    var prodTarget = Json.Serialize(ViewBag.ProdTargetData ?? new List<int>());
    var prodActual = Json.Serialize(ViewBag.ProdActualData ?? new List<int>());
    
    var orderLabels = Json.Serialize(ViewBag.OrderChartLabels ?? new List<string>());
    var orderCounts = Json.Serialize(ViewBag.OrderChartCounts ?? new List<int>());
    
    var recentOrders = ViewBag.RecentOrders as List<LouietexERP.Models.Order> ?? new List<LouietexERP.Models.Order>();
    
    // QC Calculation
    int totalQC = ViewBag.TotalQC ?? 0;
    int qcPassed = ViewBag.QCPassed ?? 0;
    int qcFailed = ViewBag.QCFailed ?? 0;
    int qcRecheck = ViewBag.QCRecheck ?? 0;

    double pctPassed = totalQC > 0 ? ((double)qcPassed / totalQC) * 100 : 0;
    double pctFailed = totalQC > 0 ? ((double)qcFailed / totalQC) * 100 : 0;
    double pctRecheck = totalQC > 0 ? ((double)qcRecheck / totalQC) * 100 : 0;

    // Fetch user for greeting
    var dashUser = await UserManager.GetUserAsync(User);
    var dashFullName = dashUser?.FullName ?? "User";
}

<style>
    /* Dashboard specific variables & overrides */
    :root {
        --dash-card-radius: 14px;
        --dash-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }
    
    .dash-gradient-header {
        background: linear-gradient(135deg, #5b6ee1 0%, #7d4aa3 100%);
        border-radius: 20px;
        padding: 30px;
        color: white;
        margin-bottom: 30px;
        box-shadow: 0 10px 30px rgba(91, 110, 225, 0.2);
    }
    
    .dash-time-pill {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        padding: 8px 20px;
        border-radius: 50px;
        font-size: 14px;
        border: 1px solid rgba(255, 255, 255, 0.3);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .kpi-card {
        background: white;
        border-radius: var(--dash-card-radius);
        padding: 24px;
        box-shadow: var(--dash-shadow);
        height: 100%;
        border: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .kpi-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
    }

    .kpi-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }
    .bg-light-primary { background: #eef2ff; color: #4e73df; }
    .bg-light-success { background: #e8f9f2; color: #1cc88a; }
    .bg-light-warning { background: #fff8e8; color: #f6c23e; }
    .bg-light-danger { background: #fdf0f0; color: #e74a3b; }
    .bg-light-info { background: #e6fbfe; color: #36b9cc; }
    
    .kpi-title { font-size: 11px; text-transform: uppercase; letter-spacing: 0.8px; color: #858796; font-weight: 700; margin-bottom: 6px; }
    .kpi-value { font-size: 32px; font-weight: 800; color: #2d2f3e; margin-bottom: 8px; line-height: 1; }
    .kpi-trend { font-size: 12px; font-weight: 600; display: flex; align-items: center; gap: 4px; }
    .trend-up   { color: #1cc88a; }
    .trend-down { color: #e74a3b; }
    .trend-warn { color: #f6c23e; }
    .trend-info { color: #4e73df; }
    .trend-muted{ color: #858796; }

    .panel-card {
        background: white;
        border-radius: var(--dash-card-radius);
        box-shadow: var(--dash-shadow);
        border: none;
        height: 100%;
    }
    .panel-header {
        padding: 20px 24px;
        border-bottom: 1px solid #f0f0f5;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .panel-title {
        font-size: 16px;
        font-weight: 700;
        color: #4e73df;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .panel-body { padding: 24px; }

    .table-modern th {
        font-size: 12px;
        text-transform: uppercase;
        color: #858796;
        font-weight: 600;
        border-bottom: 1px solid #e3e6f0;
        padding-bottom: 12px;
    }
    .table-modern td {
        padding: 16px 8px;
        vertical-align: middle;
        border-bottom: 1px solid #f8f9fa;
        color: #5a5c69;
        font-size: 14px;
    }
    
    .status-badge { padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .status-pending { background: #eef2ff; color: #4e73df; }
    .status-production { background: #fff8e8; color: #f6c23e; }
    .status-completed { background: #e8f9f2; color: #1cc88a; }
    .status-shipped { background: #e6fbfe; color: #36b9cc; }
</style>

<!-- 1. Gradient Header -->
<div class="dash-gradient-header d-flex flex-column flex-md-row justify-content-between align-items-md-center">
    <div>
        <h2 class="fw-bold mb-2">@greeting, @dashFullName! 👋</h2>

        <p class="mb-0 text-white-50 fs-6">Here’s what’s happening with your business today.</p>
    </div>
    <div class="mt-3 mt-md-0">
        <div class="dash-time-pill">
            <i class="bi bi-calendar3"></i>
            <span id="liveDateTime">@DateTime.Now.ToString("dddd, MMMM d, yyyy 'at' h:mm tt")</span>
        </div>
    </div>
</div>

<!-- 2. KPI Cards -->
<style>
    .kpi-card-link { text-decoration: none; color: inherit; display: block; }
    .kpi-card-link:hover .kpi-card { transform: translateY(-6px); box-shadow: 0 10px 30px rgba(0,0,0,0.12); }
    .kpi-card-link .kpi-card { cursor: pointer; }
</style>

<div class="row g-4 mb-4">
    <!-- Total Orders -->
    @if (isMerchandiser || isAdmin || isSuperAdmin)
    {
        <div class="col-xl-3 col-md-6">
            <a href="/Orders/Index" class="kpi-card-link">
                <div class="kpi-card d-flex align-items-center gap-3">
                    <div class="kpi-icon bg-light-primary flex-shrink-0"><i class="bi bi-cart2"></i></div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="kpi-title">Total Orders</div>
                        <div class="kpi-value">@ViewBag.TotalOrders</div>
                        <div class="kpi-trend trend-up"><i class="bi bi-arrow-up-right"></i> @ViewBag.TrendOrders</div>
                    </div>
                </div>
            </a>
        </div>
    }

    <!-- Running Production -->
    @if (isProductionManager || isAdmin || isSuperAdmin)
    {
        <div class="col-xl-3 col-md-6">
            <a href="/Productions/Index?status=Running" class="kpi-card-link">
                <div class="kpi-card d-flex align-items-center gap-3">
                    <div class="kpi-icon bg-light-success flex-shrink-0"><i class="bi bi-gear-wide-connected"></i></div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="kpi-title">Running Production</div>
                        <div class="kpi-value">@ViewBag.RunningProductions</div>
                        <div class="kpi-trend trend-info"><i class="bi bi-activity"></i> @ViewBag.TrendRunning</div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-xl-3 col-md-6">
            <a href="/Productions/Index?status=Completed" class="kpi-card-link">
                <div class="kpi-card d-flex align-items-center gap-3">
                    <div class="kpi-icon bg-light-warning flex-shrink-0"><i class="bi bi-check-circle"></i></div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="kpi-title">Completed Production</div>
                        <div class="kpi-value">@ViewBag.CompletedProductions</div>
                        <div class="kpi-trend trend-up"><i class="bi bi-arrow-up-right"></i> @ViewBag.TrendCompleted</div>
                    </div>
                </div>
            </a>
        </div>
    }

    <!-- QC Stats -->
    @if (isQC || isAdmin || isSuperAdmin)
    {
        <div class="col-xl-3 col-md-6">
            <a href="/QC/Index?status=Pending" class="kpi-card-link">
                <div class="kpi-card d-flex align-items-center gap-3">
                    <div class="kpi-icon flex-shrink-0" style="background:#f3e8ff; color:#7d4aa3;"><i class="bi bi-shield-check"></i></div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="kpi-title">Pending QC</div>
                        <div class="kpi-value">@ViewBag.PendingQC</div>
                        <div class="kpi-trend @(ViewBag.PendingQC > 0 ? "trend-warn" : "trend-up")">
                            <i class="bi @(ViewBag.PendingQC > 0 ? "bi-exclamation-triangle" : "bi-check2-circle")"></i> @ViewBag.TrendQC
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-xl-3 col-md-6">
            <a href="/QC/Index?status=Failed" class="kpi-card-link">
                <div class="kpi-card d-flex align-items-center gap-3 @(ViewBag.QCFailedItems > 0 ? "border-danger border-opacity-25" : "")">
                    <div class="kpi-icon bg-light-danger flex-shrink-0 @(ViewBag.QCFailedItems > 0 ? "pulse-danger" : "")">
                        <i class="bi bi-shield-x"></i>
                    </div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="kpi-title">QC Failed Batches</div>
                        <div class="kpi-value text-danger">@ViewBag.QCFailedItems</div>
                        <div class="kpi-trend @((bool)ViewBag.IsQCHealthy ? "trend-up" : "trend-down")">
                            <i class="bi @((bool)ViewBag.IsQCHealthy ? "bi-check2-circle" : "bi-arrow-down-right")"></i> @ViewBag.TrendQCFailed
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }

    <!-- Employees -->
    @if (isHR || isAdmin || isSuperAdmin)
    {
        <div class="col-xl-3 col-md-6">
            <a href="/Employees/Index" class="kpi-card-link">
                <div class="kpi-card d-flex align-items-center gap-3">
                    <div class="kpi-icon bg-light-info flex-shrink-0"><i class="bi bi-people"></i></div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="kpi-title">Total Employees</div>
                        <div class="kpi-value">@ViewBag.TotalEmployees</div>
                        <div class="kpi-trend trend-info"><i class="bi bi-person-check"></i> @ViewBag.TrendEmployees</div>
                    </div>
                </div>
            </a>
        </div>
    }

    @if (isAdmin || isSuperAdmin)
    {


        <!-- Low Stock -->
        <div class="col-xl-3 col-md-6">
            <a href="/Inventories/LowStock" class="kpi-card-link">
                <div class="kpi-card d-flex align-items-center gap-3 @(ViewBag.LowStockItems > 0 ? "border-warning border-opacity-50" : "")">
                    <div class="kpi-icon bg-light-warning flex-shrink-0 @(ViewBag.LowStockItems > 0 ? "pulse-warning text-warning" : "text-primary")">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="kpi-title">Low Stock Items</div>
                        <div class="kpi-value @(ViewBag.LowStockItems > 0 ? "text-warning" : "")">@ViewBag.LowStockItems</div>
                        <div class="kpi-trend @((bool)ViewBag.IsStockHealthy ? "trend-up" : "trend-down")">
                            <i class="bi @((bool)ViewBag.IsStockHealthy ? "bi-check2-circle" : "bi-exclamation-triangle")"></i> @ViewBag.TrendLowStock
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

<!-- 3. Charts Row -->
@if (isAdmin || isSuperAdmin || isProductionManager || isMerchandiser)
{
    <div class="row g-4 mb-4">
        <!-- Production Line Chart -->
        <div class="col-xl-8 col-lg-7">
            <div class="panel-card">
                <div class="panel-header d-flex justify-content-between align-items-center">
                    <h6 class="panel-title">
                        <i class="bi bi-graph-up text-primary"></i> 
                        Production Overview (<span id="prodTimeframeDisplay">@ViewBag.TimeframeDisplay</span>): 
                        <span id="prodTotalQty" class="text-dark fw-bold ms-1">@ViewBag.TotalProdActual.ToString("N0")</span>
                    </h6>
                    
                    <div class="dropdown">
                        <button class="btn btn-sm btn-light border-0 bg-light rounded-pill px-3 dropdown-toggle" type="button" id="timeframeDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 12px; font-weight: 600; color: #4e73df;">
                            <i class="bi bi-calendar-event me-1"></i> Timeframe
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg" aria-labelledby="timeframeDropdown" style="border-radius: 12px; font-size: 13px;">
                            <li><a class="dropdown-item py-2" href="javascript:void(0)" onclick="updateProductionTimeline('daily')"><i class="bi bi-view-list me-2"></i> Daily View</a></li>
                            <li><a class="dropdown-item py-2" href="javascript:void(0)" onclick="updateProductionTimeline('weekly')"><i class="bi bi-calendar-week me-2"></i> Weekly View</a></li>
                            <li><a class="dropdown-item py-2" href="javascript:void(0)" onclick="updateProductionTimeline('monthly')"><i class="bi bi-calendar-month me-2"></i> Monthly View</a></li>
                        </ul>
                    </div>
                </div>
                <div class="panel-body">
                    <div style="height: 300px; width: 100%;">
                        <canvas id="productionChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Doughnut Chart -->
        <div class="col-xl-4 col-lg-5">
            <div class="panel-card">
                <div class="panel-header">
                    <h6 class="panel-title"><i class="bi bi-clipboard2-check text-primary"></i> Order Status</h6>
                </div>
                <div class="panel-body d-flex flex-column align-items-center">
                    <!-- Chart on Top -->
                    <div style="min-height: 300px; width: 100%; position: relative;" class="mb-3">
                        @if (ViewBag.OrderChartCounts != null && ((int[])ViewBag.OrderChartCounts).Sum() > 0)
                        {
                            <canvas id="orderChart"></canvas>
                        }
                        else
                        {
                            <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-muted py-5">
                                <i class="bi bi-clipboard2-x fs-1 mb-2 opacity-25"></i>
                                <p>No orders available</p>
                            </div>
                        }
                    </div>

                    <!-- Legend Underneath -->
                    <div id="orderChartLegend" class="w-100 pt-3 border-top border-light"></div>
                </div>
            </div>
        </div>
    </div>
}

<!-- 4. Bottom Data Panels Row -->
<div class="row g-4">
    <!-- Recent Orders -->
    @if (isAdmin || isSuperAdmin || isMerchandiser)
    {
        <div class="col-xl-7 col-lg-6">
            <div class="panel-card">
                <div class="panel-header">
                    <h6 class="panel-title"><i class="bi bi-receipt text-primary"></i> Recent Orders</h6>
                    <a href="/Orders/Index" class="btn btn-sm btn-link text-decoration-none">View all orders <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="panel-body p-0">
                    <div class="table-responsive">
                        <table class="table table-modern table-borderless mb-0 w-100 px-4 d-block d-md-table">
                            <thead>
                                <tr>
                                    <th class="ps-4">Order No.</th>
                                    <th>Buyer</th>
                                    <th>Style</th>
                                    <th>Status</th>
                                    <th class="pe-4">Due Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (recentOrders.Any())
                                {
                                    foreach(var order in recentOrders)
                                    {
                                        string badgeClass = order.Status.Contains("Pending") ? "status-pending" :
                                                            order.Status.Contains("Production") ? "status-production" :
                                                            order.Status.Contains("Shipped") ? "status-shipped" : "status-completed";
                                        <tr>
                                            <td class="ps-4 fw-bold text-dark">ORD-@order.Id.ToString("D4")</td>
                                            <td>@order.BuyerName</td>
                                            <td>@order.StyleCode</td>
                                            <td><span class="status-badge @badgeClass">@order.Status</span></td>
                                            <td class="pe-4">@order.DeliveryDate.ToString("MMM dd, yyyy")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">No recent orders found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Recent Activity Feed -->
    <div class="col-xl-5 col-lg-6">
        <div class="panel-card h-100">
            <div class="panel-header">
                <h6 class="panel-title"><i class="bi bi-lightning-charge text-primary"></i> System Pulse (Recent Activity)</h6>
                <span class="badge bg-light text-primary rounded-pill fw-medium">Live Feed</span>
            </div>
            <div class="panel-body">
                <div class="timeline-modern">
                    @if (ViewBag.ActivityFeed != null)
                    {
                        var activities = (List<LouietexERP.Controllers.DashboardController.ActivityItem>)ViewBag.ActivityFeed;
                        foreach (var activity in activities)
                        {
                            <div class="d-flex mb-4 last-child-mb-0">
                                <div class="flex-shrink-0 me-3">
                                    <div class="rounded-circle @activity.IconBg @activity.IconText d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        <i class="bi @activity.Icon fs-5"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 border-bottom pb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="mb-0 fw-bold text-dark" style="font-size: 14px;">@activity.Title</h6>
                                        <small class="text-muted" style="font-size: 11px;">@LouietexERP.Models.SD.GetTimeAgo(activity.Timestamp)</small>
                                    </div>
                                    <p class="mb-0 text-muted" style="font-size: 13px;">@activity.Subtitle</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-inboxes fs-1 opacity-25 d-block mb-2"></i>
                            No recent activities logged.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 5. Recent Users Row -->
@if (isAdmin || isSuperAdmin)
{
    var recentUsers = ViewBag.RecentRegisteredUsers as List<LouietexERP.Models.ApplicationUser> ?? new List<LouietexERP.Models.ApplicationUser>();
    
    <div class="row g-4 mt-2">
        <div class="col-12">
            <div class="panel-card shadow-sm border-0">
                <div class="panel-header bg-white border-bottom py-3">
                    <h6 class="panel-title mb-0 fw-bold"><i class="bi bi-person-badge text-primary me-2"></i> Recent Registered Users</h6>
                    <a href="/UserManagement/PendingApprovals" class="btn btn-sm btn-outline-primary rounded-pill px-3">Manage All</a>
                </div>
                <div class="panel-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-uppercase fs-xs text-muted">User</th>
                                    <th class="py-3 text-uppercase fs-xs text-muted">Registration Date</th>
                                    <th class="py-3 text-uppercase fs-xs text-muted text-center">Status</th>
                                    <th class="pe-4 py-3 text-uppercase fs-xs text-muted text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (recentUsers.Any())
                                {
                                    foreach (var user in recentUsers)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-sm me-3 bg-light-primary text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 38px; height: 38px;">
                                                        @(user.FullName?.Substring(0, 1).ToUpper() ?? "U")
                                                    </div>
                                                    <div>
                                                        <div class="fw-bold text-dark">@user.FullName</div>
                                                        <div class="small text-muted">@user.Email</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="text-dark">@LouietexERP.Models.SD.GetTimeAgo(user.RegistrationDate)</div>
                                                <div class="small text-muted">@user.RegistrationDate.ToString("MMM dd, h:mm tt")</div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-light-warning text-warning border border-warning-subtle rounded-pill px-3 py-2" style="font-size: 0.75rem;">
                                                    <i class="bi bi-clock-history me-1"></i> Pending Approval
                                                </span>
                                            </td>
                                            <td class="pe-4 text-end">
                                                <form asp-controller="UserManagement" asp-action="Approve" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <button type="submit" class="btn btn-sm btn-success rounded-pill px-3 shadow-sm">Approve</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted italic">
                                            <i class="bi bi-person-check fs-2 mb-2 d-block opacity-25"></i>
                                            No new registrations pending approval.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Set dynamic date in header interval
        setInterval(() => {
            const el = document.getElementById('liveDateTime');
            if(el) {
                const now = new Date();
                const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: 'numeric', minute: '2-digit' };
                el.innerText = now.toLocaleDateString('en-US', options).replace(' at', ' at'); // fallback formatting
            }
        }, 60000);

        // Global references for charts
        let productionChartInstance;
        let orderChartInstance;

        // Toggle data visibility for Order Chart
        function toggleOrderData(index, element) {
            if (orderChartInstance) {
                const isVisible = orderChartInstance.getDataVisibility(index);
                orderChartInstance.toggleDataVisibility(index);
                orderChartInstance.update();
                
                // Visual feedback for legend item
                if (isVisible) {
                    element.style.opacity = '0.4';
                    element.style.textDecoration = 'line-through';
                } else {
                    element.style.opacity = '1';
                    element.style.textDecoration = 'none';
                }
            }
        }

        // AJAX Update function for production timeline
        async function updateProductionTimeline(timeframe) {
            try {
                const btn = document.getElementById('timeframeDropdown');
                const originalText = btn.innerHTML;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Loading...';
                btn.disabled = true;

                const response = await fetch(`/Dashboard/GetProductionChartData?timeframe=${timeframe}`);
                const data = await response.json();

                if (productionChartInstance) {
                    productionChartInstance.data.labels = data.labels;
                    productionChartInstance.data.datasets[0].data = data.actual;
                    productionChartInstance.data.datasets[1].data = data.target;
                    productionChartInstance.update();
                    document.getElementById('prodTimeframeDisplay').innerText = data.timeframeDisplay;
                    document.getElementById('prodTotalQty').innerText = data.totalActual.toLocaleString();
                }

                btn.innerHTML = originalText;
                btn.disabled = false;
            } catch (error) {
                console.error('Error fetching chart data:', error);
                alert('Failed to load chart data. Please try again.');
            }
        }

        // Chart.js Implementations
        document.addEventListener("DOMContentLoaded", function () {
            
            Chart.defaults.font.family = "'Inter', 'Segoe UI', Roboto, sans-serif";
            Chart.defaults.color = '#858796';

            // 1. Line Chart (Production)
            const prodCtx = document.getElementById('productionChart');
            if (prodCtx) {
                const ctx = prodCtx.getContext('2d');
                const gradient = ctx.createLinearGradient(0, 0, 0, 300);
                gradient.addColorStop(0, 'rgba(78, 115, 223, 0.2)');
                gradient.addColorStop(1, 'rgba(78, 115, 223, 0.0)');

                productionChartInstance = new Chart(prodCtx, {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(prodLabels),
                        datasets: [
                            {
                                label: 'Actual Output',
                                data: @Html.Raw(prodActual),
                                borderColor: '#4e73df',
                                backgroundColor: gradient,
                                borderWidth: 3,
                                fill: true,
                                tension: 0.4,
                                pointBackgroundColor: '#fff',
                                pointBorderColor: '#4e73df',
                                pointBorderWidth: 2,
                                pointRadius: 4,
                                pointHoverRadius: 6,
                                pointHoverBackgroundColor: '#4e73df',
                                pointHoverBorderColor: '#fff',
                                pointHoverBorderWidth: 2,
                                segment: {
                                    borderColor: ctx => '#4e73df',
                                    borderWidth: 3
                                }
                            },
                            {
                                label: 'Target Output',
                                data: @Html.Raw(prodTarget),
                                borderColor: '#b2baff',
                                borderDash: [5, 5],
                                borderWidth: 2,
                                fill: false,
                                tension: 0.4,
                                pointRadius: 0
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: {
                            duration: 2000,
                            easing: 'easeOutQuart'
                        },
                        plugins: {
                            legend: {
                                position: 'top',
                                align: 'end',
                                labels: { 
                                    boxWidth: 8, 
                                    usePointStyle: true,
                                    padding: 20,
                                    font: { size: 12, weight: '600' }
                                }
                            },
                            tooltip: {
                                backgroundColor: '#fff',
                                titleColor: '#333',
                                bodyColor: '#666',
                                borderColor: '#e3e6f0',
                                borderWidth: 1,
                                padding: 15,
                                displayColors: false,
                                caretPadding: 10,
                                callbacks: {
                                    label: function(item) {
                                        return item.dataset.label + ': ' + item.formattedValue + ' units';
                                    }
                                }
                            }
                        },
                        scales: {
                            x: { 
                                grid: { display: false },
                                ticks: { font: { size: 11 } }
                            },
                            y: { 
                                grid: { borderDash: [3, 3], color: '#f0f0f0', drawBorder: false },
                                ticks: { font: { size: 11 }, padding: 10 },
                                beginAtZero: true
                            }
                        }
                    }
                });
            }

            // 2. Doughnut Chart (Orders)
            const orderCtx = document.getElementById('orderChart');
            if (orderCtx) {
                const labels = @Html.Raw(orderLabels);
                const data = @Html.Raw(orderCounts);
                
                // Premium color palette
                const colors = [
                    '#4f46e5', '#10b981', '#f59e0b', '#0ea5e9', '#ef4444', 
                    '#8b5cf6', '#f472b6', '#06b6d4', '#6366f1', '#fb7185'
                ];

                orderChartInstance = new Chart(orderCtx, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: data,
                            backgroundColor: colors,
                            hoverOffset: 10,
                            borderWidth: 0,
                            borderRadius: 4,
                            spacing: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '65%',
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#fff',
                                titleColor: '#1e293b',
                                bodyColor: '#64748b',
                                borderColor: '#e2e8f0',
                                borderWidth: 1,
                                padding: 12,
                                cornerRadius: 10,
                                displayColors: true,
                                boxPadding: 6
                            }
                        }
                    },
                    plugins: [{
                        id: 'centerText',
                        afterDraw: (chart) => {
                            const { ctx, chartArea: { top, bottom, left, right, width, height } } = chart;
                            
                            // Calculate visible total
                            const visibleTotal = chart.data.datasets[0].data
                                .filter((v, i) => chart.getDataVisibility(i))
                                .reduce((a, b) => a + b, 0);

                            ctx.save();
                            ctx.font = 'bold 34px Inter';
                            ctx.fillStyle = '#1e293b';
                            ctx.textAlign = 'center';
                            ctx.textBaseline = 'middle';
                            ctx.fillText(visibleTotal.toLocaleString(), left + width / 2, top + height / 2 - 5);
                            
                            ctx.font = '600 13px Inter';
                            ctx.fillStyle = '#94a3b8';
                            ctx.letterSpacing = '1px';
                            ctx.fillText('ORDERS', left + width / 2, top + height / 2 + 20);
                            ctx.restore();
                        }
                    }]
                });

                // Generate Premium Legend
                const legendContainer = document.getElementById('orderChartLegend');
                if (legendContainer) {
                    const total = data.reduce((a, b) => a + b, 0);
                    let html = '<div class="row g-2">';
                    
                    labels.forEach((label, i) => {
                        const val = data[i];
                        const pct = total > 0 ? ((val / total) * 100).toFixed(1) : 0;
                        const color = colors[i % colors.length];
                        
                        html += `
                            <div class="col-6">
                                <div class="d-flex align-items-center justify-content-between p-2 rounded-3 hover-bg-light transition-all cursor-pointer" 
                                     onclick="toggleOrderData(${i}, this)" 
                                     style="user-select: none; border: 1px solid transparent;">
                                    <div class="d-flex align-items-center overflow-hidden">
                                        <div class="me-2 flex-shrink-0" style="width: 10px; height: 10px; border-radius: 3px; background-color: ${color}; box-shadow: 0 2px 4px ${color}44"></div>
                                        <div class="d-flex flex-column overflow-hidden">
                                            <span class="small fw-bold text-secondary text-truncate" style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px;">${label}</span>
                                            <span class="fw-bold text-dark" style="font-size: 13px;">${val}</span>
                                        </div>
                                    </div>
                                    <div class="text-end flex-shrink-0 ms-2">
                                        <span class="badge bg-light text-muted border-0" style="font-size: 10px; font-weight: 700; background-color: #f8fafc !important;">${pct}%</span>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                    
                    html += '</div>';
                    legendContainer.innerHTML = html;
                }
            }
        });
    </script>
}