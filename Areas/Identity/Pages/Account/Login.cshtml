@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<h2 class="text-center mb-4">Louietex ERP Login</h2>

<div class="row">
    <div class="col-md-6 mx-auto">
        <section>
            <form id="account" method="post">
                @Html.AntiForgeryToken()

                <h5 class="text-center">Use your account to log in</h5>
                <hr />

                <!-- ✅ Shows errors (including approval message) -->
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- EMAIL -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                    <label asp-for="Input.Email"></label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <!-- PASSWORD -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" placeholder="password" />
                    <label asp-for="Input.Password"></label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <!-- REMEMBER ME -->
                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label" asp-for="Input.RememberMe"></label>
                </div>

                <!-- LOGIN BUTTON -->
                <button type="submit" class="w-100 btn btn-primary btn-lg">Log in</button>

                <!-- LINKS -->
                <div class="mt-3 text-center">
                    <a asp-page="./ForgotPassword">Forgot password?</a><br />
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create account</a><br />
                   
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}