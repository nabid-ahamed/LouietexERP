@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
    ViewData["HideNav"] = true; // optional (hide navbar)
}
<div class="login-logo-top">
    <a href="/HomeController1/Landing">
        <img src="~/images/logo.png" alt="Logo" />
    </a>
</div>
<div class="login-wrapper d-flex justify-content-center align-items-center">

    <div class="login-card shadow-lg p-4">

        <h2 class="fw-bold mb-2">Login</h2>
        <p class="text-secondary mb-4">Welcome! Please enter your details.</p>

        <form method="post" id="loginForm">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <!-- EMAIL -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control rounded-pill px-4" placeholder="Email" />
                <label class="ms-3">Email address</label>
            </div>

            <!-- PASSWORD -->
            <div class="form-floating mb-3 position-relative">
                <input asp-for="Input.Password"
                       type="password"
                       class="form-control rounded-pill px-4"
                       id="passwordInput"
                       placeholder="Password" />
                <label class="ms-3">Password</label>

                <!-- 👁️ Toggle -->
                <i id="eyeIcon"
                   class="bi bi-eye position-absolute"
                   onclick="togglePassword()"
                   style="right:20px; top:50%; transform:translateY(-50%); cursor:pointer;"></i>
            </div>

            <!-- REMEMBER + FORGOT -->
            <div class="d-flex justify-content-between mb-3">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label">Remember me</label>
                </div>

                <!--  <a asp-page="./ForgotPassword" class="fw-bold text-decoration-none">Forgot?</a> -->
            </div>

            <!-- BUTTON -->
            <button type="submit"
                    id="loginBtn"
                    class="btn btn-primary w-100 rounded-pill py-3 fw-bold d-flex justify-content-center align-items-center">

                <span id="btnText">Sign In</span>

                <span id="btnSpinner"
                      class="spinner-border spinner-border-sm ms-2 d-none"
                      role="status"></span>
            </button>

            <!-- LINK -->
            <p class="text-center mt-3">
                Don't have an account?
                <a asp-page="./Register" class="fw-bold text-decoration-none">Create account</a>
            </p>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword() {
            const input = document.getElementById("passwordInput");
            const icon = document.getElementById("eyeIcon");

            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            }
        }

        document.getElementById("loginForm").addEventListener("submit", function () {
            document.getElementById("btnText").textContent = "Signing...";
            document.getElementById("btnSpinner").classList.remove("d-none");
            document.getElementById("loginBtn").disabled = true;
        });
    </script>
}