
@page
@model RegisterModel
@{
    ViewData["HideNav"] = true;
}

<h2 class="text-center mb-4">Create Account</h2>

<div class="register-container d-flex align-items-center justify-content-center">

    <div class="register-card shadow-lg p-4 p-md-5">

        <!-- HEADER -->
        <div class="text-center mb-4">
            <img src="~/images/logo.png" class="register-logo mb-3" />
            <h2 class="fw-bold">Create Account</h2>
            <p class="text-secondary">Join the Louietex ERP network</p>
        </div>

        <!-- FORM -->
        <form id="registerForm" method="post" asp-route-returnUrl="@Model.ReturnUrl">

            @Html.AntiForgeryToken()

            <!-- VALIDATION -->
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <!-- FULL NAME -->
            <div class="form-floating mb-3">
                <input asp-for="Input.FullName"
                       class="form-control rounded-pill px-4"
                       placeholder="Full Name" />
                <label class="ms-3">Full Name</label>
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>

            <!-- EMAIL -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Email"
                       class="form-control rounded-pill px-4"
                       placeholder="Email" />
                <label class="ms-3">Email Address</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <!-- PASSWORD ROW -->
            <div class="row g-2">

                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password"
                               type="password"
                               class="form-control rounded-pill px-4"
                               placeholder="Password" />
                        <label class="ms-3">Password</label>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.ConfirmPassword"
                               type="password"
                               class="form-control rounded-pill px-4"
                               placeholder="Confirm Password" />
                        <label class="ms-3">Confirm</label>
                    </div>
                </div>

            </div>

            <span asp-validation-for="Input.Password" class="text-danger"></span>

            <!-- BUTTON -->
            <button type="submit"
                    class="w-100 btn btn-primary btn-lg rounded-pill shadow-sm py-3 fw-bold mt-3 mb-4">
                Register Now
            </button>

            <!-- LOGIN LINK -->
            <div class="text-center">
                <p class="text-secondary small">
                    Already have an account?
                    <a asp-page="./Login" class="fw-bold text-decoration-none">
                        Sign In
                    </a>
                </p>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

