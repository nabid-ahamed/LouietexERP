@page
@model LouietexERP.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Profile";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">

            <!-- STATUS MESSAGE -->
            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="alert @(Model.StatusMessage.StartsWith("Error") ? "alert-danger" : "alert-success") alert-dismissible fade show">
                    @Model.StatusMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model.HasPendingRequest)
            {
                <div class="alert alert-warning shadow-sm border-0">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Pending Request:</strong> You have a profile change request waiting for admin approval. You cannot submit another request until the current one is processed.
                </div>
            }

            <div class="card shadow border-0 rounded-4 overflow-hidden">

                <!-- HEADER BANNER -->
                <div class="p-4 text-white d-flex align-items-center gap-3"
                     style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                    <i class="bi bi-person-circle fs-1"></i>
                    <div>
                        <h4 class="mb-0 fw-bold">Edit Profile</h4>
                        <small class="opacity-75">Manage your personal information</small>
                    </div>
                </div>

                <div class="card-body p-4">

                    <!-- UNIFIED FORM -->
                    <form method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- PROFILE PICTURE SECTION -->
                        <div class="text-center mb-4">
                            @if (!string.IsNullOrEmpty(Model.ApprovedProfilePicture))
                            {
                                <img src="@Model.ApprovedProfilePicture"
                                     class="rounded-circle border border-3 border-primary shadow"
                                     style="width:110px; height:110px; object-fit:cover;" />
                            }
                            else
                            {
                                <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center border border-3 border-primary shadow"
                                     style="width:110px; height:110px;">
                                    <i class="bi bi-person-fill text-white fs-1"></i>
                                </div>
                            }

                            <div class="mt-2">
                                @if (!string.IsNullOrEmpty(Model.PendingProfilePicture))
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-clock me-1"></i> Old picture pending approval
                                    </span>
                                }
                            </div>

                            <div class="mt-3">
                                <label class="form-label d-block text-muted small">Upload New Picture</label>
                                <div class="d-flex justify-content-center">
                                    <input type="file" name="profilePicture" accept="image/*"
                                           class="form-control form-control-sm w-auto" disabled="@Model.HasPendingRequest" />
                                </div>
                            </div>
                        </div>

                        <hr />

                        <!-- Full Name -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Full Name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-person"></i>
                                </span>
                                <input asp-for="Input.FullName" class="form-control"
                                       placeholder="Enter your full name" disabled="@Model.HasPendingRequest" />
                            </div>
                            <span asp-validation-for="Input.FullName" class="text-danger"></span>
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <input asp-for="Input.Email" class="form-control"
                                       placeholder="Enter email address" disabled="@Model.HasPendingRequest" />
                            </div>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <!-- Username (readonly) -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Username</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-at"></i>
                                </span>
                                <input type="text" class="form-control bg-light"
                                       value="@Model.Username" readonly />
                            </div>
                        </div>

                        <!-- Phone Number -->
                        <div class="mb-4">
                            <label asp-for="Input.PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-telephone"></i>
                                </span>
                                <input asp-for="Input.PhoneNumber" class="form-control"
                                       placeholder="Enter phone number" disabled="@Model.HasPendingRequest" />
                            </div>
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg rounded-3" disabled="@Model.HasPendingRequest">
                                <i class="bi bi-save me-2"></i> Save Changes
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>